# ══════════════════════════════════════════════
#  .gitignore — Sistema de Gestión Académica
# ══════════════════════════════════════════════

# ── Dependencias ────────────────────────────
node_modules/

# ── Variables de entorno (NUNCA subir) ──────
.env
.env.local
.env.production

# ── Archivos subidos por usuarios ───────────
uploads/

# ── Logs ────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Archivos temporales de Windows ──────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Archivos de editores ─────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── PM2 (producción) ────────────────────────
.pm2/

# ── Sistema operativo ───────────────────────
.DS_Store
