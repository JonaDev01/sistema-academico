<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'admin' }) %>
<div id="main-content">

  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/admin/corte" class="btn btn-sm"
         style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i><span class="btn-text">Volver</span>
      </a>
      <h1 class="page-title">
        <i class="bi bi-mortarboard me-2" style="color:var(--accent)"></i>Fin de Año — <%= anio %>
      </h1>
    </div>
  </div>

  <div class="p-4">
    <% if (mensaje) { %>
    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-check-circle-fill"></i><%= mensaje %>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-exclamation-circle-fill"></i><%= error %>
    </div>
    <% } %>

    <%# Selector de grado %>
    <div class="card mb-4">
      <div class="card-header-custom"><i class="bi bi-funnel me-2"></i>Seleccionar grado</div>
      <div class="p-3">
        <form method="GET" action="/admin/fin-de-anio">
          <div class="row g-3 align-items-end">
            <div class="col-12 col-md-6">
              <select name="grado_id" class="form-select" required onchange="this.form.submit()">
                <option value="">Seleccionar grado...</option>
                <% grados.forEach(g => { %>
                <option value="<%= g.id %>" <%= gradoSel && gradoSel.id == g.id ? 'selected' : '' %>>
                  <%= g.nombre %>
                </option>
                <% }); %>
              </select>
            </div>
            <div class="col-12 col-md-6" style="font-size:0.82rem;color:#64748B">
              <i class="bi bi-info-circle me-1"></i>
              Un estudiante repite si tiene <strong>3 o más materias</strong> con promedio menor a 60.
            </div>
          </div>
        </form>
      </div>
    </div>

    <% if (!gradoSel) { %>
    <div class="card p-5 text-center">
      <i class="bi bi-mortarboard" style="font-size:2.5rem;color:#D3D1C7"></i>
      <p class="mt-3 mb-0" style="color:#94A3B8">Selecciona un grado para calcular los resultados.</p>
    </div>

    <% } else if (resultados.length === 0) { %>
    <div class="card p-4 text-center">
      <p class="mb-0" style="color:#94A3B8">No hay estudiantes activos en este grado.</p>
    </div>

    <% } else { %>

    <%# Resumen %>
    <%
      const aprobados  = resultados.filter(r => r.estado === 'aprobado').length;
      const repitentes = resultados.filter(r => r.estado === 'repitente').length;
      const sinNotas   = resultados.filter(r => r.estado === 'sin_notas').length;
    %>
    <div class="row g-3 mb-4">
      <div class="col-4">
        <div class="card p-3 text-center" style="border-left:4px solid #1E7E4A">
          <div style="font-size:2rem;font-weight:700;color:#1E7E4A"><%= aprobados %></div>
          <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase">Aprobados</div>
        </div>
      </div>
      <div class="col-4">
        <div class="card p-3 text-center" style="border-left:4px solid #D4870A">
          <div style="font-size:2rem;font-weight:700;color:#D4870A"><%= repitentes %></div>
          <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase">Repitentes</div>
        </div>
      </div>
      <div class="col-4">
        <div class="card p-3 text-center" style="border-left:4px solid #94A3B8">
          <div style="font-size:2rem;font-weight:700;color:#94A3B8"><%= sinNotas %></div>
          <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase">Sin notas</div>
        </div>
      </div>
    </div>

    <%# Tabla de resultados %>
    <div class="card mb-4">
      <div class="card-header-custom">
        <i class="bi bi-table me-2"></i>Resultados — <%= gradoSel.nombre %>
      </div>
      <div class="table-responsive">
        <table class="table table-sm mb-0" style="font-size:0.82rem">
          <thead style="background:#F8FAFC">
            <tr>
              <th style="padding:0.7rem 1rem;color:#475569;font-weight:600;font-size:0.72rem;text-transform:uppercase">Estudiante</th>
              <th class="text-center" style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.72rem;text-transform:uppercase">Materias perdidas</th>
              <th class="text-center" style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.72rem;text-transform:uppercase">Resultado</th>
              <th style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.72rem;text-transform:uppercase">Detalle</th>
            </tr>
          </thead>
          <tbody>
            <% resultados.forEach((r, i) => {
              const cfg = {
                aprobado:  { bg:'#DCFCE7', color:'#1E7E4A', label:'Aprobado' },
                repitente: { bg:'#FFF8E6', color:'#D4870A', label:'Repitente' },
                sin_notas: { bg:'#F1F5F9', color:'#94A3B8', label:'Sin notas' },
              }[r.estado] || {};
            %>
            <tr style="border-bottom:1px solid #F8FAFC">
              <td style="padding:0.65rem 1rem">
                <div style="font-weight:600;color:var(--navy)">
                  <%= r.estudiante.apellido1 %> <%= r.estudiante.apellido2 || '' %>
                </div>
                <div style="font-size:0.75rem;color:#64748B">
                  <%= r.estudiante.nombre1 %> <%= r.estudiante.nombre2 || '' %>
                </div>
              </td>
              <td class="text-center" style="padding:0.65rem">
                <% if (r.estado !== 'sin_notas') { %>
                <span style="font-size:1.1rem;font-weight:700;color:<%= r.materiasPerdidas >= 3 ? '#D4870A' : '#1E7E4A' %>">
                  <%= r.materiasPerdidas %> / <%= r.materiasConNota %>
                </span>
                <% } else { %>
                <span style="color:#94A3B8">—</span>
                <% } %>
              </td>
              <td class="text-center" style="padding:0.65rem">
                <span class="badge" style="background:<%= cfg.bg %>;color:<%= cfg.color %>;font-size:0.75rem">
                  <%= cfg.label %>
                </span>
              </td>
              <td style="padding:0.65rem">
                <div class="d-flex flex-wrap gap-1">
                  <% r.detalle.forEach(d => { %>
                  <span class="badge"
                        style="font-size:0.65rem;font-weight:500;
                               background:<%= d.promedio === null ? '#F1F5F9' : d.perdida ? '#FEE2E2' : '#DCFCE7' %>;
                               color:<%= d.promedio === null ? '#94A3B8' : d.perdida ? '#C0392B' : '#1E7E4A' %>">
                    <%= d.nombre %> <%= d.promedio !== null ? '(' + d.promedio + ')' : '' %>
                  </span>
                  <% }); %>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <%# Confirmar aplicar %>
    <div class="card" style="border:2px solid #D4870A">
      <div style="padding:1rem 1.25rem;background:#FFF8E6">
        <h6 style="color:#D4870A;font-weight:700;margin-bottom:0.5rem">
          <i class="bi bi-exclamation-triangle me-1"></i>Aplicar resultados
        </h6>
        <p style="font-size:0.82rem;color:#64748B;margin-bottom:1rem">
          Al confirmar se marcarán <strong><%= repitentes %> estudiantes como repitentes</strong>
          y se promoverán <strong><%= aprobados %> estudiantes</strong>
          <% if (gradoSiguiente) { %> al <strong><%= gradoSiguiente.nombre %></strong><% } else { %> (sin grado siguiente)<% } %>.
          Esta acción no es fácilmente reversible.
        </p>
        <form method="POST" action="/admin/fin-de-anio/aplicar"
              onsubmit="return confirm('¿Confirmas aplicar los resultados de fin de año para <%= gradoSel.nombre %>? Esta acción no es fácilmente reversible.')">
          <input type="hidden" name="grado_id"          value="<%= gradoSel.id %>">
          <input type="hidden" name="grado_siguiente_id" value="<%= gradoSiguiente ? gradoSiguiente.id : '' %>">
          <input type="hidden" name="anio"              value="<%= anio %>">
          <button type="submit" class="btn"
                  style="background:#D4870A;color:#fff;border:none">
            <i class="bi bi-check-lg me-1"></i>Confirmar y aplicar resultados
          </button>
        </form>
      </div>
    </div>

    <% } %>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
