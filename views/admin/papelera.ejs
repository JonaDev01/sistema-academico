<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'papelera' }) %>
<div id="main-content">

  <div id="topbar">
    <h1 class="page-title">
      <i class="bi bi-trash me-2" style="color:var(--accent)"></i>Papelera
    </h1>
  </div>

  <div class="p-4">
    <% if (mensaje) { %>
    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-check-circle-fill"></i><%= mensaje %>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-exclamation-circle-fill"></i><%= error %>
    </div>
    <% } %>

    <div class="alert py-2 mb-4" style="background:#FFF8E6;border:1px solid #C8A84B;border-radius:8px;font-size:0.82rem;color:#D4870A">
      <i class="bi bi-exclamation-triangle me-1"></i>
      <strong>Eliminar permanentemente borrará todos los datos asociados</strong> (notas, asignaciones, etc.) y no se puede deshacer.
    </div>

    <%# Macro para tabla de papelera %>
    <% function seccion(titulo, icono, items, tipo, nombreFn) { %>
    <div class="card mb-4">
      <div class="card-header-custom">
        <i class="bi bi-<%= icono %> me-2"></i><%= titulo %>
        <span style="font-size:0.8rem;opacity:0.7;margin-left:0.5rem"><%= items.length %> elementos</span>
      </div>
      <% if (items.length === 0) { %>
      <div class="p-3 text-center" style="color:#94A3B8;font-size:0.875rem">
        Sin elementos inactivos
      </div>
      <% } else { %>
      <table class="table table-sm mb-0" style="font-size:0.875rem">
        <thead style="background:#F8FAFC">
          <tr>
            <th style="padding:0.65rem 1rem;color:#475569;font-weight:600;font-size:0.72rem;text-transform:uppercase">Nombre</th>
            <th style="padding:0.65rem;color:#475569;font-weight:600;font-size:0.72rem;text-transform:uppercase">Detalle</th>
            <th style="width:180px"></th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
          <tr style="border-bottom:1px solid #F8FAFC">
            <td style="padding:0.65rem 1rem;font-weight:600;color:var(--navy)"><%= nombreFn(item) %></td>
            <td style="padding:0.65rem 0.75rem;color:#64748B;font-size:0.8rem">
              <% if (tipo === 'materia') { %><%= item.grado ? item.grado.nombre : '—' %>
              <% } else if (tipo === 'estudiante') { %><%= item.grado ? item.grado.nombre : 'Sin grado' %> · <%= item.estado_matricula %>
              <% } else if (tipo === 'docente') { %>Usuario: <%= item.usuario ? item.usuario.username : '—' %>
              <% } else { %>—<% } %>
            </td>
            <td style="padding:0.65rem 0.75rem;text-align:right">
              <div class="d-flex gap-1 justify-content-end">
                <form method="POST" action="/admin/papelera/restaurar" style="display:inline">
                  <input type="hidden" name="tipo" value="<%= tipo %>">
                  <input type="hidden" name="id"   value="<%= item.id %>">
                  <button type="submit" class="btn btn-sm"
                          style="background:#DCFCE7;color:#1E7E4A;border:none;padding:0.25rem 0.6rem;font-size:0.75rem">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Restaurar
                  </button>
                </form>
                <form method="POST" action="/admin/papelera/eliminar" style="display:inline"
                      onsubmit="return confirm('¿Eliminar permanentemente? Esta acción no se puede deshacer.')">
                  <input type="hidden" name="tipo" value="<%= tipo %>">
                  <input type="hidden" name="id"   value="<%= item.id %>">
                  <button type="submit" class="btn btn-sm"
                          style="background:#FEE2E2;color:#C0392B;border:none;padding:0.25rem 0.6rem;font-size:0.75rem">
                    <i class="bi bi-trash me-1"></i>Eliminar
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>
    </div>
    <% } %>

    <%- seccion('Grados inactivos',    'diagram-3',    gradosInactivos,    'grado',      item => item.nombre) %>
    <%- seccion('Materias inactivas',  'book',         materiasInactivas,  'materia',    item => item.nombre) %>
    <%- seccion('Estudiantes retirados/egresados', 'person-x', estudiantesInactivos, 'estudiante', item => `${item.apellido1} ${item.apellido2 || ''}, ${item.nombre1} ${item.nombre2 || ''}`) %>
    <%- seccion('Docentes inactivos',  'person-badge', docentesInactivos,  'docente',    item => `${item.nombre} ${item.apellido}`) %>

  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
