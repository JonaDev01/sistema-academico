<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'perfil' }) %>
<div id="main-content">

  <div id="topbar">
    <h1 class="page-title">
      <i class="bi bi-gear me-2" style="color:var(--accent)"></i>Mi Perfil
    </h1>
  </div>

  <div class="p-4">
    <% if (mensaje) { %>
    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-check-circle-fill"></i><%= mensaje %>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-exclamation-circle-fill"></i><%= error %>
    </div>
    <% } %>

    <div class="row justify-content-center">
      <div class="col-12 col-md-7 col-lg-5">
        <div class="card">
          <div class="card-header-custom">
            <i class="bi bi-person-circle me-2"></i>Datos del administrador
          </div>
          <div class="p-4">
            <form method="POST" action="/admin/perfil">

              <div class="mb-3">
                <label class="form-label">Nombre</label>
                <input type="text" name="nombre" class="form-control"
                       value="<%= usuario.nombre %>" required>
              </div>

              <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <input type="email" name="email" class="form-control"
                       value="<%= usuario.email %>" required>
              </div>

              <hr style="border-color:#F1F5F9;margin:1.25rem 0">

              <p style="font-size:0.8rem;color:#64748B;margin-bottom:0.75rem">
                Para cambiar la contraseña completa los tres campos. Si no quieres cambiarla déjalos vacíos.
              </p>

              <div class="mb-3">
                <label class="form-label">Contraseña actual</label>
                <input type="password" name="password_actual" class="form-control"
                       placeholder="Solo si deseas cambiar la contraseña">
              </div>

              <div class="mb-4">
                <label class="form-label">Nueva contraseña</label>
                <input type="password" name="password_nuevo" class="form-control"
                       placeholder="Mínimo 6 caracteres" minlength="6">
              </div>

              <button type="submit" class="btn btn-navy w-100">
                <i class="bi bi-check-lg me-1"></i>Guardar cambios
              </button>

            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
