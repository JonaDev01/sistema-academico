<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'admin' }) %>
<div id="main-content">

  <div id="topbar">
    <h1 class="page-title">
      <i class="bi bi-calendar-check me-2" style="color:var(--accent)"></i>Gestión de Corte Activo
    </h1>
  </div>

  <div class="p-4">
    <% if (mensaje) { %>
    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-check-circle-fill"></i><%= mensaje %>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-exclamation-circle-fill"></i><%= error %>
    </div>
    <% } %>

    <div class="row g-4">

      <%# Corte actual %>
      <div class="col-12 col-md-5">
        <div class="card" style="border-left:4px solid var(--accent)">
          <div class="card-header-custom">
            <i class="bi bi-circle-fill me-2" style="color:#4ADE80;font-size:0.6rem"></i>Corte activo actualmente
          </div>
          <div class="p-4 text-center">
            <% if (periodoActivo) { %>
            <div style="font-size:4rem;font-weight:900;color:var(--navy);font-family:'Playfair Display',serif;line-height:1">
              C<%= periodoActivo.corte %>
            </div>
            <div style="font-size:1rem;color:#64748B;margin-top:0.5rem">
              Corte <%= periodoActivo.corte %> — <%= periodoActivo.anio %>
            </div>
            <% } else { %>
            <div style="font-size:1.5rem;color:#94A3B8">Sin corte activo</div>
            <% } %>
          </div>
        </div>

        <%# Link a fin de año %>
        <a href="/admin/fin-de-anio"
           class="card mt-3 p-3 text-decoration-none d-flex flex-row align-items-center gap-3"
           style="border-left:4px solid #6D28D9">
          <div style="width:44px;height:44px;border-radius:50%;background:#EDE9FE;
                      display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="bi bi-mortarboard" style="color:#6D28D9;font-size:1.2rem"></i>
          </div>
          <div>
            <div style="font-weight:600;color:var(--navy);font-size:0.9rem">Fin de año</div>
            <div style="font-size:0.78rem;color:#64748B">Calcular repitentes y promover estudiantes</div>
          </div>
        </a>
      </div>

      <%# Selector de corte %>
      <div class="col-12 col-md-7">
        <div class="card">
          <div class="card-header-custom">
            <i class="bi bi-arrow-left-right me-2"></i>Cambiar corte activo
          </div>
          <div class="p-4">

            <p style="font-size:0.85rem;color:#64748B;margin-bottom:1.25rem">
              Selecciona el corte que quieres activar. Los docentes solo podrán
              registrar notas en el corte activo.
            </p>

            <div class="row g-3 mb-4">
              <% periodos.forEach(p => { %>
              <div class="col-6">
                <div class="p-3 rounded-3 text-center"
                     style="border:2px solid <%= p.activo ? 'var(--accent)' : '#E2E8F0' %>;
                            background:<%= p.activo ? '#FFF8E6' : '#F8FAFC' %>;
                            cursor:pointer"
                     onclick="seleccionarCorte(<%= p.id %>, <%= p.corte %>)">
                  <div style="font-size:1.8rem;font-weight:800;color:<%= p.activo ? 'var(--accent)' : '#94A3B8' %>">
                    C<%= p.corte %>
                  </div>
                  <div style="font-size:0.75rem;color:#64748B">Corte <%= p.corte %> — <%= p.anio %></div>
                  <% if (p.activo) { %>
                  <span class="badge mt-1" style="background:#C8A84B;color:#fff;font-size:0.65rem">ACTIVO</span>
                  <% } %>
                </div>
              </div>
              <% }); %>
            </div>

            <form method="POST" action="/admin/corte/cambiar" id="form-corte">
              <input type="hidden" name="periodo_id" id="periodo-id-input" value="">
              <button type="submit" id="btn-cambiar" class="btn btn-navy w-100" disabled>
                <i class="bi bi-check-lg me-1"></i>Confirmar cambio de corte
              </button>
            </form>

            <div id="preview-cambio" class="mt-3" style="display:none">
              <div class="alert py-2 mb-0" style="background:#FFF8E6;border:1px solid #C8A84B;border-radius:8px;font-size:0.82rem;color:#D4870A">
                <i class="bi bi-exclamation-triangle me-1"></i>
                Vas a activar el <strong id="preview-texto"></strong>. Los docentes solo verán este corte al registrar notas.
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function seleccionarCorte(id, corte) {
    document.getElementById('periodo-id-input').value = id;
    document.getElementById('btn-cambiar').disabled = false;
    document.getElementById('preview-cambio').style.display = 'block';
    document.getElementById('preview-texto').textContent = `Corte ${corte}`;
  }
</script>
</body>
</html>
