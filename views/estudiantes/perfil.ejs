<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'estudiantes' }) %>

<div id="main-content">
  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/estudiantes" class="btn btn-sm"
         style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i><span class="btn-text">Volver</span>
      </a>
      <h1 class="page-title">
        <i class="bi bi-person-lines-fill me-2" style="color:var(--accent)"></i>
        Perfil del estudiante
      </h1>
    </div>
    <% if (usuario.rol === 'admin' || usuario.rol === 'docente') { %>
    <div class="d-flex gap-2">
      <a href="/estudiantes/<%= estudiante.id %>/notas"
         class="btn btn-sm"
         style="background:#EDE9FE;color:#6D28D9;border:1px solid #6D28D920">
        <i class="bi bi-journal-check me-1"></i><span class="btn-text">Ver notas</span>
      </a>
      <a href="/estudiantes/<%= estudiante.id %>/editar"
         class="btn btn-sm btn-navy">
        <i class="bi bi-pencil me-1"></i><span class="btn-text">Editar</span>
      </a>
    </div>
    <% } %>
  </div>

  <div class="p-4">

    <%# ── Encabezado del perfil ── %>
    <div class="card mb-4" style="border-left:4px solid var(--accent)">
      <div class="card-body py-3 px-4">
        <div class="row align-items-center g-3">
          <div class="col-auto">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:60px;height:60px;background:var(--navy)">
              <i class="bi bi-person-fill text-white" style="font-size:1.6rem"></i>
            </div>
          </div>
          <div class="col">
            <h2 style="font-family:'Playfair Display',serif;color:var(--navy);
                       font-size:1.4rem;margin:0">
              <%= estudiante.nombre1 %>
              <%= estudiante.nombre2 ? estudiante.nombre2 + ' ' : '' %><%= estudiante.apellido1 %>
              <%= estudiante.apellido2 || '' %>
            </h2>
            <div class="d-flex flex-wrap gap-3 mt-1">
              <span style="font-size:0.82rem;color:#64748B">
                <i class="bi bi-hash"></i> <%= estudiante.codigo_estudiante %>
              </span>
              <span style="font-size:0.82rem;color:#64748B">
                <i class="bi bi-mortarboard"></i>
                <%= estudiante.grado ? estudiante.grado.nombre : '—' %>
              </span>
              <%
                const estadoCfg = {
                  activo:   { bg:'#DCFCE7', color:'#1E7E4A', label:'Activo' },
                  retirado: { bg:'#FEE2E2', color:'#C0392B', label:'Retirado' },
                  egresado: { bg:'#DBEAFE', color:'#1A4A8A', label:'Egresado' },
                }[estudiante.estado_matricula] || {};
              %>
              <span class="badge"
                    style="background:<%= estadoCfg.bg %>;color:<%= estadoCfg.color %>">
                <%= estadoCfg.label %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">

      <%# ── Columna izquierda ── %>
      <div class="col-12 col-lg-6">

        <%# Datos personales %>
        <div class="card mb-4">
          <div class="card-header-custom">
            <i class="bi bi-person me-2"></i>Datos personales
          </div>
          <div class="p-0">
            <% const fila = (label, valor) => { %>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:160px"><%= label %></span>
              <span style="color:var(--navy);font-weight:500"><%= valor || '—' %></span>
            </div>
            <% }; %>
            <% fila('Código estudiante', estudiante.codigo_estudiante); %>
            <% fila('Código único (DPI)', estudiante.codigo_unico); %>
            <% fila('ID externo', estudiante.id_externo); %>
            <% fila('Fecha de nacimiento',
              estudiante.fecha_nacimiento
                ? new Date(estudiante.fecha_nacimiento).toLocaleDateString('es-GT', {day:'2-digit',month:'long',year:'numeric'})
                : null); %>
            <%
              let edad = '—';
              if (estudiante.fecha_nacimiento) {
                const hoy = new Date();
                const nac = new Date(estudiante.fecha_nacimiento);
                let e = hoy.getFullYear() - nac.getFullYear();
                if (hoy.getMonth() < nac.getMonth() || (hoy.getMonth() === nac.getMonth() && hoy.getDate() < nac.getDate())) e--;
                edad = e + ' años';
              }
            %>
            <% fila('Edad', edad); %>
            <% fila('Género', estudiante.genero ? (estudiante.genero.charAt(0).toUpperCase() + estudiante.genero.slice(1)) : null); %>
            <% fila('Nivel', estudiante.nivel ? (estudiante.nivel.charAt(0).toUpperCase() + estudiante.nivel.slice(1)) : null); %>
            <% fila('Departamento', estudiante.departamento); %>
            <% fila('Dirección', estudiante.direccion); %>
          </div>
        </div>

        <%# Estado académico %>
        <div class="card">
          <div class="card-header-custom">
            <i class="bi bi-clipboard-check me-2"></i>Estado académico
          </div>
          <div class="p-0">
            <%
              const pagoCfg = {
                al_dia:   { bg:'#DCFCE7', color:'#1E7E4A', label:'Al día' },
                pendiente:{ bg:'#FFF8E6', color:'#D4870A', label:'Pendiente' },
              }[estudiante.estado_pago] || {};
              const becaCfg = {
                ninguna:    { bg:'#F1EFE8', color:'#888780', label:'Sin beca' },
                becado:     { bg:'#EDE9FE', color:'#6D28D9', label:'Becado' },
                semi_becado:{ bg:'#CCFBF1', color:'#0F6E56', label:'Semi-becado' },
              }[estudiante.tipo_beca] || {};
            %>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:160px">Estado matrícula</span>
              <span class="badge" style="background:<%= estadoCfg.bg %>;color:<%= estadoCfg.color %>">
                <%= estadoCfg.label %>
              </span>
            </div>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:160px">Estado de pago</span>
              <span class="badge" style="background:<%= pagoCfg.bg %>;color:<%= pagoCfg.color %>">
                <%= pagoCfg.label %>
              </span>
            </div>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:160px">Beca</span>
              <span class="badge" style="background:<%= becaCfg.bg %>;color:<%= becaCfg.color %>">
                <%= becaCfg.label %>
              </span>
            </div>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:160px">Parte del proyecto</span>
              <span style="color:var(--navy);font-weight:500">
                <%= estudiante.en_proyecto ? 'Sí' : 'No' %>
              </span>
            </div>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:160px">Programa</span>
              <span style="color:var(--navy);font-weight:500"><%= estudiante.programa || '—' %></span>
            </div>
            <% if (estudiante.motivo_registro) { %>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:160px">Motivo de registro</span>
              <span style="color:var(--navy);font-weight:500"><%= estudiante.motivo_registro %></span>
            </div>
            <% } %>
            <% if (estudiante.descripcion_retiro) { %>
            <div class="d-flex px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:160px">Motivo de retiro</span>
              <span style="color:#C0392B;font-weight:500"><%= estudiante.descripcion_retiro %></span>
            </div>
            <% } %>
          </div>
        </div>

      </div>

      <%# ── Columna derecha ── %>
      <div class="col-12 col-lg-6">

        <%# Datos de familia %>
        <div class="card mb-4">
          <div class="card-header-custom">
            <i class="bi bi-people me-2"></i>Datos de familia
          </div>
          <div class="p-0">
            <div class="px-4 py-3 border-bottom">
              <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.05em;
                          color:#94A3B8;margin-bottom:0.5rem">Madre</div>
              <div style="font-weight:600;color:var(--navy);font-size:0.9rem">
                <%= estudiante.nombre_madre || '—' %>
              </div>
              <% if (estudiante.cedula_madre) { %>
              <div style="font-size:0.8rem;color:#64748B;margin-top:2px">
                <i class="bi bi-credit-card me-1"></i><%= estudiante.cedula_madre %>
              </div>
              <% } %>
            </div>
            <div class="px-4 py-3">
              <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.05em;
                          color:#94A3B8;margin-bottom:0.5rem">Padre</div>
              <div style="font-weight:600;color:var(--navy);font-size:0.9rem">
                <%= estudiante.nombre_padre || '—' %>
              </div>
              <% if (estudiante.cedula_padre) { %>
              <div style="font-size:0.8rem;color:#64748B;margin-top:2px">
                <i class="bi bi-credit-card me-1"></i><%= estudiante.cedula_padre %>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <%# Acciones rápidas %>
        <div class="card">
          <div class="card-header-custom">
            <i class="bi bi-lightning me-2"></i>Acciones rápidas
          </div>
          <div class="p-3 d-flex flex-column gap-2">
            <a href="/estudiantes/<%= estudiante.id %>/notas"
               class="btn d-flex align-items-center gap-2"
               style="background:#EDE9FE;color:#6D28D9;border:none;text-align:left">
              <i class="bi bi-journal-check"></i>
              Ver todas las notas
            </a>
            <% if (usuario.rol === 'admin') { %>
            <a href="/estudiantes/<%= estudiante.id %>/editar"
               class="btn d-flex align-items-center gap-2"
               style="background:#EFF6FF;color:#1A4A8A;border:none;text-align:left">
              <i class="bi bi-pencil"></i>
              Editar información
            </a>
            <a href="/boletin"
               class="btn d-flex align-items-center gap-2"
               style="background:#FBEAF0;color:#993556;border:none;text-align:left">
              <i class="bi bi-file-earmark-pdf"></i>
              Generar boletín PDF
            </a>
            <% } %>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
