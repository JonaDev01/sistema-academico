<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'estudiantes' }) %>

<div id="main-content">

  <%# ── Topbar ── %>
  <div id="topbar">
    <h1 class="page-title">
      <i class="bi bi-people me-2" style="color:var(--accent)"></i>Estudiantes
    </h1>
    <% if (usuario.rol === 'admin') { %>
    <div class="d-flex gap-2">
      <a href="/estudiantes/importar" class="btn btn-sm"
         style="background:#DCFCE7;color:#1E7E4A;border:1px solid #1E7E4A20">
        <i class="bi bi-file-earmark-excel me-1"></i>Importar Excel
      </a>
      <a href="/estudiantes/nuevo" class="btn btn-sm btn-navy">
        <i class="bi bi-plus-lg me-1"></i>Nuevo estudiante
      </a>
    </div>
    <% } %>
  </div>

  <div class="p-4">

    <%# ── Alertas ── %>
    <% if (mensaje) { %>
    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3"
         style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-check-circle-fill"></i><%= mensaje %>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3"
         style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-exclamation-circle-fill"></i><%= error %>
    </div>
    <% } %>

    <%# ── Filtros ── %>
    <div class="card mb-4">
      <div class="p-3">
        <form method="GET" action="/estudiantes" id="form-filtros">
          <div class="row g-2 align-items-end">

            <%# Búsqueda libre %>
            <div class="col-12 col-md-3">
              <label class="form-label" style="font-size:0.75rem;color:#475569;
                     text-transform:uppercase;font-weight:600">Buscar</label>
              <div style="position:relative">
                <i class="bi bi-search"
                   style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);
                          color:#94A3B8;font-size:0.85rem"></i>
                <input type="text" name="busqueda" class="form-control form-control-sm"
                       style="padding-left:2.2rem"
                       placeholder="Nombre, apellido o código..."
                       value="<%= filtros.busqueda || '' %>">
              </div>
            </div>

            <%# Grado %>
            <div class="col-6 col-md-2">
              <label class="form-label" style="font-size:0.75rem;color:#475569;
                     text-transform:uppercase;font-weight:600">Grado</label>
              <select name="grado_id" class="form-select form-select-sm">
                <option value="">Todos</option>
                <% grados.forEach(g => { %>
                <option value="<%= g.id %>"
                  <%= filtros.grado_id == g.id ? 'selected' : '' %>>
                  <%= g.nombre %>
                </option>
                <% }); %>
              </select>
            </div>

            <%# Estado matrícula %>
            <div class="col-6 col-md-2">
              <label class="form-label" style="font-size:0.75rem;color:#475569;
                     text-transform:uppercase;font-weight:600">Estado</label>
              <select name="estado_matricula" class="form-select form-select-sm">
                <option value="">Todos</option>
                <option value="activo"   <%= filtros.estado_matricula === 'activo'   ? 'selected' : '' %>>Activo</option>
                <option value="retirado" <%= filtros.estado_matricula === 'retirado' ? 'selected' : '' %>>Retirado</option>
                <option value="egresado" <%= filtros.estado_matricula === 'egresado' ? 'selected' : '' %>>Egresado</option>
              </select>
            </div>

            <%# Beca %>
            <div class="col-6 col-md-2">
              <label class="form-label" style="font-size:0.75rem;color:#475569;
                     text-transform:uppercase;font-weight:600">Beca</label>
              <select name="tipo_beca" class="form-select form-select-sm">
                <option value="">Todos</option>
                <option value="ninguna"    <%= filtros.tipo_beca === 'ninguna'    ? 'selected' : '' %>>Sin beca</option>
                <option value="becado"     <%= filtros.tipo_beca === 'becado'     ? 'selected' : '' %>>Becado</option>
                <option value="semi_becado"<%= filtros.tipo_beca === 'semi_becado'? 'selected' : '' %>>Semi-becado</option>
              </select>
            </div>

            <%# Pago %>
            <div class="col-6 col-md-2">
              <label class="form-label" style="font-size:0.75rem;color:#475569;
                     text-transform:uppercase;font-weight:600">Pago</label>
              <select name="estado_pago" class="form-select form-select-sm">
                <option value="">Todos</option>
                <option value="al_dia"   <%= filtros.estado_pago === 'al_dia'   ? 'selected' : '' %>>Al día</option>
                <option value="pendiente"<%= filtros.estado_pago === 'pendiente'? 'selected' : '' %>>Pendiente</option>
              </select>
            </div>

            <%# Botones %>
            <div class="col-12 col-md-1 d-flex gap-2">
              <button type="submit" class="btn btn-sm btn-navy flex-grow-1">
                <i class="bi bi-funnel"></i>
              </button>
              <a href="/estudiantes" class="btn btn-sm"
                 style="background:var(--bg);border:1px solid #E2E8F0;color:#64748B">
                <i class="bi bi-x"></i>
              </a>
            </div>

          </div>
        </form>
      </div>
    </div>

    <%# ── Tabla de estudiantes ── %>
    <div class="card">
      <div class="p-3 d-flex justify-content-between align-items-center"
           style="border-bottom:1px solid #F1F5F9">
        <span style="font-size:0.875rem;color:#64748B">
          <strong style="color:var(--navy)"><%= estudiantes.length %></strong> estudiantes encontrados
        </span>
        <% if (usuario.rol === 'admin') { %>
        <a href="/estudiantes/exportar" class="btn btn-sm"
           style="background:#FFF8E6;color:#D4870A;border:1px solid #D4870A20;font-size:0.78rem">
          <i class="bi bi-download me-1"></i>Exportar Excel
        </a>
        <% } %>
      </div>

      <% if (estudiantes.length === 0) { %>
      <div class="p-5 text-center">
        <i class="bi bi-people" style="font-size:2.5rem;color:#D3D1C7"></i>
        <p class="mt-3 mb-2" style="color:#64748B">No se encontraron estudiantes con esos filtros.</p>
        <a href="/estudiantes" style="font-size:0.875rem;color:var(--blue)">Limpiar filtros</a>
      </div>
      <% } else { %>
      <div class="table-responsive">
        <table id="tabla-estudiantes" class="table table-sm mb-0" style="font-size:0.875rem">
          <thead style="background:#F8FAFC">
            <tr>
              <th style="padding:0.7rem 1rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Código</th>
              <th style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Nombre</th>
              <th style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Grado</th>
              <th class="text-center" style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Estado</th>
              <th class="text-center" style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Pago</th>
              <th class="text-center" style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Beca</th>
              <th style="width:120px"></th>
            </tr>
          </thead>
          <tbody>
            <% estudiantes.forEach(est => {
              const estadoCfg = {
                activo:    { bg:'#DCFCE7', color:'#1E7E4A', label:'Activo' },
                retirado:  { bg:'#FEE2E2', color:'#C0392B', label:'Retirado' },
                egresado:  { bg:'#DBEAFE', color:'#1A4A8A', label:'Egresado' },
                repitente: { bg:'#FFF8E6', color:'#D4870A', label:'Repitente' },
              }[est.estado_matricula] || {};

              const pagoCfg = {
                al_dia:   { bg:'#DCFCE7', color:'#1E7E4A', label:'Al día' },
                pendiente:{ bg:'#FFF8E6', color:'#D4870A', label:'Pendiente' },
              }[est.estado_pago] || {};

              const becaCfg = {
                ninguna:    { bg:'#F1EFE8', color:'#888780', label:'—' },
                becado:     { bg:'#EDE9FE', color:'#6D28D9', label:'Becado' },
                semi_becado:{ bg:'#CCFBF1', color:'#0F6E56', label:'Semi' },
              }[est.tipo_beca] || {};
            %>
            <tr style="border-bottom:1px solid #F8FAFC" id="fila-<%= est.id %>">
              <td style="padding:0.65rem 1rem;color:#64748B;font-size:0.8rem;font-family:'Courier New'">
                <%= est.codigo_estudiante || '—' %>
              </td>
              <td style="padding:0.65rem 0.75rem">
                <div style="font-weight:600;color:var(--navy)">
                  <%= est.apellido1 %><%= est.apellido2 ? ' ' + est.apellido2 : '' %>
                </div>
                <div style="font-size:0.78rem;color:#64748B">
                  <%= est.nombre1 %><%= est.nombre2 ? ' ' + est.nombre2 : '' %>
                </div>
              </td>
              <td style="padding:0.65rem 0.75rem;color:#475569">
                <%= est.grado ? est.grado.nombre : '—' %>
              </td>

              <%# ── Estado matrícula — dropdown rápido ── %>
              <td class="text-center" style="padding:0.65rem 0.5rem">
                <% if (usuario.rol === 'admin') { %>
                <div class="dropdown">
                  <span class="badge dropdown-toggle"
                        id="est-badge-<%= est.id %>"
                        style="background:<%= estadoCfg.bg %>;color:<%= estadoCfg.color %>;
                               font-size:0.72rem;cursor:pointer"
                        data-bs-toggle="dropdown">
                    <%= estadoCfg.label %>
                  </span>
                  <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size:0.8rem;min-width:140px">
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'estado_matricula','activo');return false">
                      <span style="color:#1E7E4A">● Activo</span></a></li>
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'estado_matricula','repitente');return false">
                      <span style="color:#D4870A">● Repitente</span></a></li>
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'estado_matricula','retirado');return false">
                      <span style="color:#C0392B">● Retirado</span></a></li>
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'estado_matricula','egresado');return false">
                      <span style="color:#1A4A8A">● Egresado</span></a></li>
                  </ul>
                </div>
                <% } else { %>
                <span class="badge" style="background:<%= estadoCfg.bg %>;color:<%= estadoCfg.color %>;font-size:0.72rem">
                  <%= estadoCfg.label %>
                </span>
                <% } %>
              </td>

              <%# ── Estado pago — dropdown rápido ── %>
              <td class="text-center" style="padding:0.65rem 0.5rem">
                <% if (usuario.rol === 'admin') { %>
                <div class="dropdown">
                  <span class="badge dropdown-toggle"
                        id="pago-badge-<%= est.id %>"
                        style="background:<%= pagoCfg.bg %>;color:<%= pagoCfg.color %>;
                               font-size:0.72rem;cursor:pointer"
                        data-bs-toggle="dropdown">
                    <%= pagoCfg.label %>
                  </span>
                  <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size:0.8rem;min-width:130px">
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'estado_pago','al_dia');return false">
                      <span style="color:#1E7E4A">● Al día</span></a></li>
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'estado_pago','pendiente');return false">
                      <span style="color:#D4870A">● Pendiente</span></a></li>
                  </ul>
                </div>
                <% } else { %>
                <span class="badge" style="background:<%= pagoCfg.bg %>;color:<%= pagoCfg.color %>;font-size:0.72rem">
                  <%= pagoCfg.label %>
                </span>
                <% } %>
              </td>

              <%# ── Beca — dropdown rápido ── %>
              <td class="text-center" style="padding:0.65rem 0.5rem">
                <% if (usuario.rol === 'admin') { %>
                <div class="dropdown">
                  <span class="badge dropdown-toggle"
                        id="beca-badge-<%= est.id %>"
                        style="background:<%= becaCfg.bg %>;color:<%= becaCfg.color %>;
                               font-size:0.72rem;cursor:pointer"
                        data-bs-toggle="dropdown">
                    <%= becaCfg.label %>
                  </span>
                  <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size:0.8rem;min-width:140px">
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'tipo_beca','ninguna');return false">
                      <span style="color:#888780">● Sin beca</span></a></li>
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'tipo_beca','becado');return false">
                      <span style="color:#6D28D9">● Becado</span></a></li>
                    <li><a class="dropdown-item" href="#"
                           onclick="cambiarCampo(<%= est.id %>,'tipo_beca','semi_becado');return false">
                      <span style="color:#0F6E56">● Semi-becado</span></a></li>
                  </ul>
                </div>
                <% } else { %>
                <span class="badge" style="background:<%= becaCfg.bg %>;color:<%= becaCfg.color %>;font-size:0.72rem">
                  <%= becaCfg.label %>
                </span>
                <% } %>
              </td>

              <td style="padding:0.65rem 0.75rem">
                <div class="d-flex gap-1 justify-content-end align-items-center">
                  <%# Proyecto toggle rápido %>
                  <% if (usuario.rol === 'admin') { %>
                  <button class="btn btn-sm"
                          id="proy-<%= est.id %>"
                          style="background:<%= est.en_proyecto ? '#CCFBF1' : '#F1EFE8' %>;
                                 color:<%= est.en_proyecto ? '#0F6E56' : '#888780' %>;
                                 border:none;padding:0.25rem 0.5rem;font-size:0.65rem;font-weight:600"
                          title="<%= est.en_proyecto ? 'En proyecto — clic para quitar' : 'No está en proyecto — clic para agregar' %>"
                          onclick="cambiarCampo(<%= est.id %>,'en_proyecto','<%= !est.en_proyecto %>')">
                    PROY
                  </button>
                  <% } %>
                  <a href="/estudiantes/<%= est.id %>"
                     class="btn btn-sm"
                     style="background:#F1EFE8;color:#5F5E5A;border:none;padding:0.25rem 0.5rem"
                     title="Más información">
                    <i class="bi bi-info-circle" style="font-size:0.75rem"></i>
                  </a>
                  <a href="/estudiantes/<%= est.id %>/notas"
                     class="btn btn-sm"
                     style="background:#EDE9FE;color:#6D28D9;border:none;padding:0.25rem 0.5rem"
                     title="Ver notas">
                    <i class="bi bi-journal-check" style="font-size:0.75rem"></i>
                  </a>
                  <% if (usuario.rol === 'admin') { %>
                  <a href="/estudiantes/<%= est.id %>/editar"
                     class="btn btn-sm"
                     style="background:#EFF6FF;color:#1A4A8A;border:none;padding:0.25rem 0.5rem"
                     title="Editar todo">
                    <i class="bi bi-pencil" style="font-size:0.75rem"></i>
                  </a>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script>
  // ── Cambio rápido de campo desde la tabla ────────────────
  const estadoCfg = {
    activo:    { bg:'#DCFCE7', color:'#1E7E4A', label:'Activo' },
    retirado:  { bg:'#FEE2E2', color:'#C0392B', label:'Retirado' },
    egresado:  { bg:'#DBEAFE', color:'#1A4A8A', label:'Egresado' },
    repitente: { bg:'#FFF8E6', color:'#D4870A', label:'Repitente' },
  };
  const pagoCfg = {
    al_dia:   { bg:'#DCFCE7', color:'#1E7E4A', label:'Al día' },
    pendiente:{ bg:'#FFF8E6', color:'#D4870A', label:'Pendiente' },
  };
  const becaCfg = {
    ninguna:    { bg:'#F1EFE8', color:'#888780', label:'—' },
    becado:     { bg:'#EDE9FE', color:'#6D28D9', label:'Becado' },
    semi_becado:{ bg:'#CCFBF1', color:'#0F6E56', label:'Semi' },
  };

  async function cambiarCampo(id, campo, valor) {
    try {
      const resp = await fetch(`/estudiantes/${id}/campo`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ campo, valor }),
      });
      const data = await resp.json();
      if (!data.ok) { alert('Error: ' + data.mensaje); return; }

      // Actualizar badge sin recargar la página
      if (campo === 'estado_matricula') {
        const cfg = estadoCfg[valor] || {};
        const el  = document.getElementById(`est-badge-${id}`);
        if (el) { el.style.background = cfg.bg; el.style.color = cfg.color; el.textContent = cfg.label + ' '; }
      } else if (campo === 'estado_pago') {
        const cfg = pagoCfg[valor] || {};
        const el  = document.getElementById(`pago-badge-${id}`);
        if (el) { el.style.background = cfg.bg; el.style.color = cfg.color; el.textContent = cfg.label + ' '; }
      } else if (campo === 'tipo_beca') {
        const cfg = becaCfg[valor] || {};
        const el  = document.getElementById(`beca-badge-${id}`);
        if (el) { el.style.background = cfg.bg; el.style.color = cfg.color; el.textContent = cfg.label + ' '; }
      } else if (campo === 'en_proyecto') {
        const esProy = valor === 'true';
        const el = document.getElementById(`proy-${id}`);
        if (el) {
          el.style.background = esProy ? '#CCFBF1' : '#F1EFE8';
          el.style.color      = esProy ? '#0F6E56' : '#888780';
          el.title = esProy ? 'En proyecto — clic para quitar' : 'No está en proyecto — clic para agregar';
          el.setAttribute('onclick', `cambiarCampo(${id},'en_proyecto','${!esProy}')`);
        }
      }
    } catch (err) {
      alert('Error de conexión');
    }
  }

  // ── DataTables ──────────────────────────────────────────
  $(document).ready(function () {
    if ($('#tabla-estudiantes tbody tr').length > 0) {
      $('#tabla-estudiantes').DataTable({
        paging:    true,
        pageLength: 25,
        searching:  false,
        ordering:   true,
        language: {
          lengthMenu: 'Mostrar _MENU_ por página',
          info:       'Mostrando _START_ a _END_ de _TOTAL_ estudiantes',
          paginate:   { previous: '‹', next: '›' },
          emptyTable: 'No hay estudiantes',
        },
        columnDefs: [{ orderable: false, targets: -1 }],
      });
    }
  });
</script>
</body>
</html>
