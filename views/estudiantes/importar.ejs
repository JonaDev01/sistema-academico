<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'estudiantes' }) %>

<div id="main-content">
  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/estudiantes" class="btn btn-sm"
         style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
      <h1 class="page-title">
        <i class="bi bi-file-earmark-excel me-2" style="color:var(--accent)"></i><%= titulo %>
      </h1>
    </div>
  </div>

  <div class="p-4">
    <div class="row g-4">

      <%# ── Columna izquierda: formulario ── %>
      <div class="col-12 col-lg-5">
        <div class="card">
          <div class="card-header-custom">
            <i class="bi bi-upload me-2"></i>Subir archivo Excel
          </div>
          <div class="p-4">

            <form method="POST" action="/estudiantes/importar"
                  enctype="multipart/form-data" id="form-importar">

              <%# Zona de drop %>
              <div id="drop-zone"
                   style="border:2px dashed #CBD5E1;border-radius:10px;
                          padding:2rem;text-align:center;cursor:pointer;
                          transition:all 0.2s;margin-bottom:1rem"
                   onclick="document.getElementById('archivo').click()">
                <i class="bi bi-file-earmark-excel"
                   style="font-size:2.5rem;color:#1E7E4A"></i>
                <p class="mt-2 mb-1" style="color:var(--navy);font-weight:600">
                  Haz clic para seleccionar el archivo
                </p>
                <p style="font-size:0.8rem;color:#94A3B8;margin:0">
                  Formatos aceptados: .xlsx · .xls · Máximo 10MB
                </p>
              </div>

              <input type="file" name="archivo" id="archivo"
                     accept=".xlsx,.xls" style="display:none"
                     onchange="mostrarNombre(this)">

              <div id="nombre-archivo"
                   style="display:none;background:#F0FDF4;border:1px solid #DCFCE7;
                          border-radius:8px;padding:0.6rem 1rem;margin-bottom:1rem;
                          font-size:0.875rem;color:#1E7E4A">
                <i class="bi bi-check-circle me-2"></i>
                <span id="texto-archivo"></span>
              </div>

              <button type="submit" id="btn-importar"
                      class="btn btn-navy w-100" disabled>
                <i class="bi bi-cloud-upload me-1"></i>Iniciar importación
              </button>

            </form>

            <%# Instrucciones %>
            <div class="mt-4 p-3"
                 style="background:#F8FAFC;border-radius:8px;border:1px solid #E2E8F0">
              <p style="font-size:0.8rem;font-weight:600;color:var(--navy);margin-bottom:0.5rem">
                <i class="bi bi-info-circle me-1"></i>Instrucciones
              </p>
              <ul style="font-size:0.78rem;color:#64748B;margin:0;padding-left:1.2rem">
                <li>Usa el archivo Excel original del colegio sin modificar.</li>
                <li>Los estudiantes ya existentes (mismo código) se actualizan.</li>
                <li>Los estudiantes sin código reciben uno generado automáticamente.</li>
                <li>El grado se asigna según el nivel del Excel — asegúrate de haber creado los grados en el sistema primero.</li>
                <li>Campos como beca y estado de pago no están en el Excel — quedan con valor por defecto.</li>
              </ul>
            </div>

          </div>
        </div>
      </div>

      <%# ── Columna derecha: resultado ── %>
      <div class="col-12 col-lg-7">

        <% if (!resultado) { %>
        <%# Estado inicial %>
        <div class="card p-5 text-center h-100 d-flex align-items-center justify-content-center">
          <i class="bi bi-arrow-left-circle"
             style="font-size:2.5rem;color:#D3D1C7"></i>
          <p class="mt-3 mb-0" style="color:#94A3B8">
            El resultado de la importación aparecerá aquí.
          </p>
        </div>

        <% } else { %>

        <%# Resumen de resultado %>
        <div class="row g-3 mb-4">
          <div class="col-6 col-md-3">
            <div class="card p-3 text-center" style="border-left:4px solid #1E7E4A">
              <div style="font-size:1.8rem;font-weight:700;color:#1E7E4A">
                <%= resultado.importados || 0 %>
              </div>
              <div style="font-size:0.75rem;color:#64748B;text-transform:uppercase">Importados</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="card p-3 text-center" style="border-left:4px solid #1A4A8A">
              <div style="font-size:1.8rem;font-weight:700;color:#1A4A8A">
                <%= resultado.actualizados || 0 %>
              </div>
              <div style="font-size:0.75rem;color:#64748B;text-transform:uppercase">Actualizados</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="card p-3 text-center" style="border-left:4px solid #D4870A">
              <div style="font-size:1.8rem;font-weight:700;color:#D4870A">
                <%= resultado.omitidos || 0 %>
              </div>
              <div style="font-size:0.75rem;color:#64748B;text-transform:uppercase">Omitidos</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="card p-3 text-center" style="border-left:4px solid #C0392B">
              <div style="font-size:1.8rem;font-weight:700;color:#C0392B">
                <%= (resultado.errores || []).length %>
              </div>
              <div style="font-size:0.75rem;color:#64748B;text-transform:uppercase">Errores</div>
            </div>
          </div>
        </div>

        <%# Advertencias %>
        <% if (resultado.advertencias && resultado.advertencias.length > 0) { %>
        <div class="card mb-3">
          <div class="p-3 d-flex align-items-center gap-2"
               style="border-bottom:1px solid #FFF8E6;background:#FFFBF0;border-radius:10px 10px 0 0">
            <i class="bi bi-exclamation-triangle" style="color:#D4870A"></i>
            <span style="font-weight:600;color:#D4870A;font-size:0.875rem">
              <%= resultado.advertencias.length %> advertencias
            </span>
          </div>
          <div style="max-height:200px;overflow-y:auto">
            <% resultado.advertencias.forEach(adv => { %>
            <div class="px-3 py-2"
                 style="font-size:0.78rem;color:#64748B;border-bottom:1px solid #F8FAFC">
              <i class="bi bi-dot" style="color:#D4870A"></i><%= adv %>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>

        <%# Errores %>
        <% if (resultado.errores && resultado.errores.length > 0) { %>
        <div class="card mb-3">
          <div class="p-3 d-flex align-items-center gap-2"
               style="border-bottom:1px solid #FEE2E2;background:#FFF5F5;border-radius:10px 10px 0 0">
            <i class="bi bi-x-circle" style="color:#C0392B"></i>
            <span style="font-weight:600;color:#C0392B;font-size:0.875rem">
              <%= resultado.errores.length %> errores
            </span>
          </div>
          <div style="max-height:200px;overflow-y:auto">
            <% resultado.errores.forEach(err => { %>
            <div class="px-3 py-2"
                 style="font-size:0.78rem;color:#C0392B;border-bottom:1px solid #F8FAFC">
              <i class="bi bi-dot"></i><%= err %>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>

        <%# Botón ir a estudiantes %>
        <% if ((resultado.importados || 0) + (resultado.actualizados || 0) > 0) { %>
        <a href="/estudiantes" class="btn btn-navy">
          <i class="bi bi-people me-1"></i>Ver estudiantes importados
        </a>
        <% } %>

        <% } %>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function mostrarNombre(input) {
    if (input.files && input.files[0]) {
      document.getElementById('texto-archivo').textContent = input.files[0].name;
      document.getElementById('nombre-archivo').style.display = 'block';
      document.getElementById('btn-importar').disabled = false;
      document.getElementById('drop-zone').style.borderColor = '#1E7E4A';
    }
  }

  // Drag and drop
  const dz = document.getElementById('drop-zone');
  dz.addEventListener('dragover', e => {
    e.preventDefault();
    dz.style.borderColor = 'var(--navy)';
    dz.style.background  = '#F0F4F9';
  });
  dz.addEventListener('dragleave', () => {
    dz.style.borderColor = '#CBD5E1';
    dz.style.background  = 'transparent';
  });
  dz.addEventListener('drop', e => {
    e.preventDefault();
    const input  = document.getElementById('archivo');
    input.files  = e.dataTransfer.files;
    mostrarNombre(input);
    dz.style.background = 'transparent';
  });

  // Loading state al enviar
  document.getElementById('form-importar').addEventListener('submit', () => {
    const btn = document.getElementById('btn-importar');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Importando...';
    btn.disabled  = true;
  });
</script>
</body>
</html>
