<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %>
<style>
  .paso-indicator { display:flex; gap:0; margin-bottom:1.5rem; }
  .paso-item {
    flex:1; text-align:center; padding:0.6rem 0.5rem;
    font-size:0.78rem; font-weight:600; border-bottom:3px solid #E2E8F0;
    color:#94A3B8; cursor:pointer; transition:all 0.2s;
  }
  .paso-item.activo  { border-bottom-color:var(--navy); color:var(--navy); }
  .paso-item.completo{ border-bottom-color:var(--accent); color:var(--accent); }
  .paso-contenido { display:none; }
  .paso-contenido.activo { display:block; }
  .campo-req::after { content:' *'; color:#C0392B; }
</style>
</head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'estudiantes' }) %>

<div id="main-content">
  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/estudiantes" class="btn btn-sm"
         style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i><span class="btn-text">Volver</span>
      </a>
      <h1 class="page-title">
        <i class="bi bi-person-plus me-2" style="color:var(--accent)"></i><%= titulo %>
      </h1>
    </div>
  </div>

  <div class="p-4">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-9">

        <%# Errores %>
        <% if (errores && errores.length > 0) { %>
        <div class="alert alert-danger py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
          <% errores.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div><% }); %>
        </div>
        <% } %>

        <div class="card">
          <div class="card-header-custom">
            <%= estudiante && estudiante.id ? 'Editar información del estudiante' : 'Registrar nuevo estudiante' %>
          </div>

          <div class="p-4">

            <%# Indicador de pasos %>
            <div class="paso-indicator">
              <div class="paso-item <%= paso >= 1 ? (paso > 1 ? 'completo' : 'activo') : '' %>"
                   onclick="irPaso(1)">
                <i class="bi bi-person me-1"></i>Datos personales
              </div>
              <div class="paso-item <%= paso >= 2 ? (paso > 2 ? 'completo' : 'activo') : '' %>"
                   onclick="irPaso(2)">
                <i class="bi bi-people me-1"></i>Familia
              </div>
              <div class="paso-item <%= paso >= 3 ? 'activo' : '' %>"
                   onclick="irPaso(3)">
                <i class="bi bi-clipboard-check me-1"></i>Estado académico
              </div>
            </div>

            <form method="POST"
                  action="/estudiantes/<%= estudiante && estudiante.id ? estudiante.id + '/editar' : 'nuevo' %>"
                  id="form-estudiante">

              <input type="hidden" name="paso_actual" id="paso_actual" value="<%= paso %>">

              <%# ══ PASO 1: DATOS PERSONALES ══ %>
              <div class="paso-contenido <%= paso === 1 ? 'activo' : '' %>" id="paso-1">

                <div class="row g-3">

                  <div class="col-12 col-md-6">
                    <label class="form-label campo-req">Código del estudiante</label>
                    <input type="text" name="codigo_estudiante" class="form-control"
                           placeholder="Código del colegio"
                           value="<%= estudiante ? estudiante.codigo_estudiante : '' %>" required>
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label">Código único (DPI)</label>
                    <input type="text" name="codigo_unico" class="form-control"
                           placeholder="DPI o registro nacional"
                           value="<%= estudiante ? (estudiante.codigo_unico || '') : '' %>">
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label campo-req">Primer nombre</label>
                    <input type="text" name="nombre1" class="form-control"
                           value="<%= estudiante ? estudiante.nombre1 : '' %>" required>
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label">Segundo nombre</label>
                    <input type="text" name="nombre2" class="form-control"
                           value="<%= estudiante ? (estudiante.nombre2 || '') : '' %>">
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label campo-req">Primer apellido</label>
                    <input type="text" name="apellido1" class="form-control"
                           value="<%= estudiante ? estudiante.apellido1 : '' %>" required>
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label">Segundo apellido</label>
                    <input type="text" name="apellido2" class="form-control"
                           value="<%= estudiante ? (estudiante.apellido2 || '') : '' %>">
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label campo-req">Fecha de nacimiento</label>
                    <input type="date" name="fecha_nacimiento" class="form-control"
                           value="<%= estudiante && estudiante.fecha_nacimiento ? new Date(estudiante.fecha_nacimiento).toISOString().split('T')[0] : '' %>"
                           required>
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label campo-req">Género</label>
                    <select name="genero" class="form-select" required>
                      <option value="">Seleccionar...</option>
                      <option value="masculino" <%= estudiante && estudiante.genero === 'masculino' ? 'selected' : '' %>>Masculino</option>
                      <option value="femenino"  <%= estudiante && estudiante.genero === 'femenino'  ? 'selected' : '' %>>Femenino</option>
                    </select>
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label campo-req">Nivel</label>
                    <select name="nivel" class="form-select" required>
                      <option value="">Seleccionar...</option>
                      <option value="preescolar" <%= estudiante && estudiante.nivel === 'preescolar' ? 'selected' : '' %>>Preescolar</option>
                      <option value="primaria"   <%= estudiante && estudiante.nivel === 'primaria'   ? 'selected' : '' %>>Primaria</option>
                      <option value="secundaria" <%= estudiante && estudiante.nivel === 'secundaria' ? 'selected' : '' %>>Secundaria</option>
                    </select>
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label campo-req">Grado</label>
                    <select name="grado_id" class="form-select" required>
                      <option value="">Seleccionar grado...</option>
                      <% grados.forEach(g => { %>
                      <option value="<%= g.id %>"
                        <%= estudiante && estudiante.grado_id == g.id ? 'selected' : '' %>>
                        <%= g.nombre %>
                      </option>
                      <% }); %>
                    </select>
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label">Departamento</label>
                    <input type="text" name="departamento" class="form-control"
                           placeholder="Departamento de procedencia"
                           value="<%= estudiante ? (estudiante.departamento || '') : '' %>">
                  </div>

                  <div class="col-12">
                    <label class="form-label">Dirección</label>
                    <input type="text" name="direccion" class="form-control"
                           placeholder="Dirección de residencia"
                           value="<%= estudiante ? (estudiante.direccion || '') : '' %>">
                  </div>

                </div>

                <div class="d-flex justify-content-end mt-4">
                  <button type="button" class="btn btn-navy px-4" onclick="irPaso(2)">
                    Siguiente <i class="bi bi-arrow-right ms-1"></i>
                  </button>
                </div>
              </div>

              <%# ══ PASO 2: FAMILIA ══ %>
              <div class="paso-contenido <%= paso === 2 ? 'activo' : '' %>" id="paso-2">

                <div class="row g-3">

                  <div class="col-12">
                    <h6 style="color:var(--navy);font-weight:600;margin-bottom:0.25rem">
                      <i class="bi bi-person-heart me-2" style="color:var(--accent)"></i>Datos de la madre
                    </h6>
                    <hr style="margin-top:0.25rem;border-color:#F1F5F9">
                  </div>

                  <div class="col-12 col-md-8">
                    <label class="form-label">Nombre de la madre</label>
                    <input type="text" name="nombre_madre" class="form-control"
                           value="<%= estudiante ? (estudiante.nombre_madre || '') : '' %>">
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label">Cédula / DPI de la madre</label>
                    <input type="text" name="cedula_madre" class="form-control"
                           value="<%= estudiante ? (estudiante.cedula_madre || '') : '' %>">
                  </div>

                  <div class="col-12 mt-2">
                    <h6 style="color:var(--navy);font-weight:600;margin-bottom:0.25rem">
                      <i class="bi bi-person-heart me-2" style="color:var(--accent)"></i>Datos del padre
                    </h6>
                    <hr style="margin-top:0.25rem;border-color:#F1F5F9">
                  </div>

                  <div class="col-12 col-md-8">
                    <label class="form-label">Nombre del padre</label>
                    <input type="text" name="nombre_padre" class="form-control"
                           value="<%= estudiante ? (estudiante.nombre_padre || '') : '' %>">
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label">Cédula / DPI del padre</label>
                    <input type="text" name="cedula_padre" class="form-control"
                           value="<%= estudiante ? (estudiante.cedula_padre || '') : '' %>">
                  </div>

                  <div class="col-12 mt-2">
                    <h6 style="color:var(--navy);font-weight:600;margin-bottom:0.25rem">
                      <i class="bi bi-info-circle me-2" style="color:var(--accent)"></i>Datos adicionales
                    </h6>
                    <hr style="margin-top:0.25rem;border-color:#F1F5F9">
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label">Programa</label>
                    <input type="text" name="programa" class="form-control"
                           value="<%= estudiante ? (estudiante.programa || '') : '' %>">
                  </div>

                  <div class="col-12">
                    <label class="form-label">Motivo de registro</label>
                    <textarea name="motivo_registro" class="form-control" rows="2"
                              placeholder="Motivo por el que el estudiante está en el registro..."><%= estudiante ? (estudiante.motivo_registro || '') : '' %></textarea>
                  </div>

                </div>

                <div class="d-flex justify-content-between mt-4">
                  <button type="button" class="btn" onclick="irPaso(1)"
                          style="border:1px solid #E2E8F0;color:#64748B">
                    <i class="bi bi-arrow-left me-1"></i>Anterior
                  </button>
                  <button type="button" class="btn btn-navy px-4" onclick="irPaso(3)">
                    Siguiente <i class="bi bi-arrow-right ms-1"></i>
                  </button>
                </div>
              </div>

              <%# ══ PASO 3: ESTADO ACADÉMICO ══ %>
              <div class="paso-contenido <%= paso === 3 ? 'activo' : '' %>" id="paso-3">

                <div class="row g-3">

                  <div class="col-12 col-md-4">
                    <label class="form-label">Estado de matrícula</label>
                    <select name="estado_matricula" class="form-select">
                      <option value="activo"   <%= !estudiante || estudiante.estado_matricula === 'activo'   ? 'selected' : '' %>>Activo</option>
                      <option value="retirado" <%= estudiante && estudiante.estado_matricula === 'retirado' ? 'selected' : '' %>>Retirado</option>
                      <option value="egresado" <%= estudiante && estudiante.estado_matricula === 'egresado' ? 'selected' : '' %>>Egresado</option>
                    </select>
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label">Estado de pago</label>
                    <select name="estado_pago" class="form-select">
                      <option value="al_dia"   <%= !estudiante || estudiante.estado_pago === 'al_dia'   ? 'selected' : '' %>>Al día</option>
                      <option value="pendiente"<%= estudiante && estudiante.estado_pago === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
                    </select>
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label">Tipo de beca</label>
                    <select name="tipo_beca" class="form-select">
                      <option value="ninguna"    <%= !estudiante || estudiante.tipo_beca === 'ninguna'    ? 'selected' : '' %>>Sin beca</option>
                      <option value="becado"     <%= estudiante && estudiante.tipo_beca === 'becado'     ? 'selected' : '' %>>Becado</option>
                      <option value="semi_becado"<%= estudiante && estudiante.tipo_beca === 'semi_becado'? 'selected' : '' %>>Semi-becado</option>
                    </select>
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label">¿Parte del proyecto?</label>
                    <div class="d-flex gap-3 mt-1">
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="en_proyecto"
                               id="proy-si" value="true"
                               <%= estudiante && estudiante.en_proyecto ? 'checked' : '' %>>
                        <label class="form-check-label" for="proy-si">Sí</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="en_proyecto"
                               id="proy-no" value="false"
                               <%= !estudiante || !estudiante.en_proyecto ? 'checked' : '' %>>
                        <label class="form-check-label" for="proy-no">No</label>
                      </div>
                    </div>
                  </div>

                  <div class="col-12 col-md-6">
                    <label class="form-label">ID externo (sistema anterior)</label>
                    <input type="text" name="id_externo" class="form-control"
                           placeholder="ID del Excel anterior (opcional)"
                           value="<%= estudiante ? (estudiante.id_externo || '') : '' %>">
                  </div>

                  <%# Solo si está retirado %>
                  <div class="col-12" id="campo-retiro"
                       style="display:<%= estudiante && estudiante.estado_matricula === 'retirado' ? 'block' : 'none' %>">
                    <label class="form-label">Descripción del retiro</label>
                    <textarea name="descripcion_retiro" class="form-control" rows="2"
                              placeholder="Motivo o descripción del retiro..."><%= estudiante ? (estudiante.descripcion_retiro || '') : '' %></textarea>
                  </div>

                </div>

                <div class="d-flex justify-content-between mt-4">
                  <button type="button" class="btn" onclick="irPaso(2)"
                          style="border:1px solid #E2E8F0;color:#64748B">
                    <i class="bi bi-arrow-left me-1"></i>Anterior
                  </button>
                  <button type="submit" class="btn btn-navy px-4">
                    <i class="bi bi-check-lg me-1"></i>
                    <%= estudiante && estudiante.id ? 'Guardar cambios' : 'Registrar estudiante' %>
                  </button>
                </div>
              </div>

            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function irPaso(n) {
    document.querySelectorAll('.paso-contenido').forEach((el, i) => {
      el.classList.toggle('activo', i + 1 === n);
    });
    document.querySelectorAll('.paso-item').forEach((el, i) => {
      el.classList.remove('activo', 'completo');
      if (i + 1 === n)  el.classList.add('activo');
      if (i + 1 < n)    el.classList.add('completo');
    });
    document.getElementById('paso_actual').value = n;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Mostrar/ocultar campo de descripción de retiro
  document.querySelector('[name="estado_matricula"]').addEventListener('change', function() {
    document.getElementById('campo-retiro').style.display =
      this.value === 'retirado' ? 'block' : 'none';
  });
</script>
</body>
</html>
