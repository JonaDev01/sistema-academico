<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'docentes' }) %>
<div id="main-content">

  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/docentes/<%= docente.id %>" class="btn btn-sm"
         style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i>Perfil
      </a>
      <h1 class="page-title">
        <i class="bi bi-diagram-3 me-2" style="color:var(--accent)"></i><%= titulo %>
      </h1>
    </div>
  </div>

  <div class="p-4">
    <% if (mensaje) { %>
    <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-check-circle-fill"></i><%= mensaje %>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-exclamation-circle-fill"></i><%= error %>
    </div>
    <% } %>

    <div class="row g-4">

      <%# Columna izquierda: lista de asignaciones %>
      <div class="col-12 col-lg-7">
        <div class="card">
          <div class="card-header-custom">
            <i class="bi bi-list-check me-2"></i>Clases asignadas
            <span style="font-size:0.8rem;opacity:0.7;margin-left:0.5rem">
              <%= docente.asignaciones ? docente.asignaciones.length : 0 %> activas
            </span>
          </div>

          <% const asigs = docente.asignaciones || []; %>
          <% if (asigs.length === 0) { %>
          <div class="p-4 text-center">
            <i class="bi bi-diagram-3" style="font-size:2rem;color:#D3D1C7"></i>
            <p class="mt-2 mb-0" style="color:#94A3B8;font-size:0.875rem">
              Sin clases asignadas. Usa el formulario para agregar.
            </p>
          </div>
          <% } else { %>
          <table class="table table-sm mb-0" style="font-size:0.875rem">
            <thead style="background:#F8FAFC">
              <tr>
                <th style="padding:0.65rem 1rem;color:#475569;font-weight:600;font-size:0.72rem;text-transform:uppercase">Grado</th>
                <th style="padding:0.65rem;color:#475569;font-weight:600;font-size:0.72rem;text-transform:uppercase">Materia</th>
                <th style="width:60px"></th>
              </tr>
            </thead>
            <tbody>
              <% asigs.forEach(a => { %>
              <tr style="border-bottom:1px solid #F8FAFC">
                <td style="padding:0.6rem 1rem;color:var(--navy);font-weight:500">
                  <%= a.gradoAsignacion ? a.gradoAsignacion.nombre : '—' %>
                </td>
                <td style="padding:0.6rem 0.75rem">
                  <span class="badge" style="background:#DBEAFE;color:#1A4A8A;font-size:0.75rem">
                    <%= a.materia ? a.materia.nombre : '—' %>
                  </span>
                </td>
                <td style="padding:0.6rem 0.75rem;text-align:right">
                  <form method="POST"
                        action="/docentes/<%= docente.id %>/asignaciones/<%= a.id %>/eliminar"
                        style="display:inline">
                    <button type="submit" class="btn btn-sm"
                            style="background:#FFF1F0;color:#C0392B;border:none;padding:0.2rem 0.45rem"
                            onclick="return confirm('¿Eliminar esta asignación?')"
                            title="Eliminar">
                      <i class="bi bi-trash" style="font-size:0.72rem"></i>
                    </button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>

      <%# Columna derecha: formulario nueva asignación %>
      <div class="col-12 col-lg-5">
        <div class="card" style="position:sticky;top:80px">
          <div class="card-header-custom">
            <i class="bi bi-plus-circle me-2"></i>Agregar clase
          </div>
          <div class="p-4">
            <form method="POST" action="/docentes/<%= docente.id %>/asignaciones" id="form-asignacion">

              <div class="mb-3">
                <label class="form-label">Grado <span style="color:#C0392B">*</span></label>
                <select name="grado_id" id="sel-grado" class="form-select" required
                        onchange="cargarMaterias(this.value)">
                  <option value="">Seleccionar grado...</option>
                  <% grados.forEach(g => { %>
                  <option value="<%= g.id %>"><%= g.nombre %></option>
                  <% }); %>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Materia <span style="color:#C0392B">*</span></label>
                <select name="materia_id" id="sel-materia" class="form-select" required>
                  <option value="">Primero selecciona un grado...</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Año <span style="color:#C0392B">*</span></label>
                <input type="number" name="anio" id="input-anio" class="form-control"
                       value="<%= new Date().getFullYear() %>"
                       min="2024" max="2030" required>
              </div>

              <button type="submit" class="btn btn-navy w-100 mb-2">
                <i class="bi bi-plus-lg me-1"></i>Agregar materia
              </button>

            </form>

            <%# Botón agregar grado completo %>
            <div style="border-top:1px solid #F1F5F9;padding-top:0.75rem;margin-top:0.25rem">
              <p style="font-size:0.72rem;color:#94A3B8;margin-bottom:0.5rem;text-align:center">
                O agregar todas las materias del grado
              </p>
              <form method="POST" action="/docentes/<%= docente.id %>/asignaciones/grado-completo">
                <input type="hidden" name="grado_id" id="hidden-grado-id" value="">
                <input type="hidden" name="anio"     id="hidden-anio"     value="<%= new Date().getFullYear() %>">
                <button type="button" class="btn w-100"
                        style="background:#DBEAFE;color:#1A4A8A;border:1px solid #1A4A8A20"
                        onclick="asignarGradoCompleto()">
                  <i class="bi bi-collection me-1"></i>Asignar grado completo
                </button>
              </form>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Datos de grados y materias desde el servidor
  const gradosData = <%- JSON.stringify(grados.map(g => ({
    id: g.id,
    materias: (g.materias || []).map(m => ({ id: m.id, nombre: m.nombre }))
  }))) %>;

  function cargarMaterias(gradoId) {
    const sel = document.getElementById('sel-materia');
    sel.innerHTML = '<option value="">Seleccionar materia...</option>';

    // Sincronizar hidden inputs para grado completo
    document.getElementById('hidden-grado-id').value = gradoId;
    const anio = document.getElementById('input-anio');
    if (anio) document.getElementById('hidden-anio').value = anio.value;

    if (!gradoId) return;

    const grado = gradosData.find(g => g.id == gradoId);
    if (!grado || grado.materias.length === 0) {
      sel.innerHTML = '<option value="">Sin materias activas en este grado</option>';
      return;
    }

    grado.materias.forEach(m => {
      const opt = document.createElement('option');
      opt.value = m.id;
      opt.textContent = m.nombre;
      sel.appendChild(opt);
    });
  }

  function asignarGradoCompleto() {
    const gradoId = document.getElementById('hidden-grado-id').value;
    if (!gradoId) {
      alert('Primero selecciona un grado en el formulario de arriba.');
      return;
    }
    const grado    = gradosData.find(g => g.id == gradoId);
    const nombre   = grado ? grado.materias.length : 0;
    if (!confirm(`¿Asignar todas las ${nombre} materias de este grado al docente?`)) return;

    // Sincronizar año
    const anio = document.getElementById('input-anio');
    if (anio) document.getElementById('hidden-anio').value = anio.value;

    document.querySelector('form[action*="grado-completo"]').submit();
  }
</script>
</body>
</html>
