<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'docentes' }) %>
<div id="main-content">

  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/docentes" class="btn btn-sm" style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i><span class="btn-text">Volver</span>
      </a>
      <h1 class="page-title">
        <i class="bi bi-person-badge me-2" style="color:var(--accent)"></i><%= titulo %>
      </h1>
    </div>
  </div>

  <div class="p-4">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">
        <div class="card">
          <div class="card-header-custom">
            <%= docente && docente.id ? 'Editar información del docente' : 'Registrar nuevo docente' %>
          </div>
          <div class="p-4">

            <% if (errores && errores.length > 0) { %>
            <div class="alert alert-danger py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
              <% errores.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div><% }); %>
            </div>
            <% } %>

            <form method="POST"
                  action="/docentes/<%= docente && docente.id ? docente.id + '/editar' : 'nuevo' %>">

              <%# Datos personales %>
              <h6 style="color:var(--navy);font-weight:600;margin-bottom:0.75rem">
                <i class="bi bi-person me-2" style="color:var(--accent)"></i>Datos personales
              </h6>

              <div class="row g-3 mb-3">
                <div class="col-6">
                  <label class="form-label">Nombre <span style="color:#C0392B">*</span></label>
                  <input type="text" name="nombre" class="form-control"
                         value="<%= docente ? docente.nombre : '' %>" required>
                </div>
                <div class="col-6">
                  <label class="form-label">Apellido <span style="color:#C0392B">*</span></label>
                  <input type="text" name="apellido" class="form-control"
                         value="<%= docente ? docente.apellido : '' %>" required>
                </div>
                <div class="col-6">
                  <label class="form-label">Teléfono</label>
                  <input type="text" name="telefono" class="form-control"
                         placeholder="+505 0000-0000"
                         value="<%= docente ? (docente.telefono || '') : '' %>">
                </div>
                <div class="col-6">
                  <label class="form-label">Especialidad</label>
                  <input type="text" name="especialidad" class="form-control"
                         placeholder="Ej: Matemáticas, Ciencias"
                         value="<%= docente ? (docente.especialidad || '') : '' %>">
                </div>
              </div>

              <hr style="border-color:#F1F5F9;margin:1.25rem 0">

              <%# Credenciales %>
              <h6 style="color:var(--navy);font-weight:600;margin-bottom:0.75rem">
                <i class="bi bi-key me-2" style="color:var(--accent)"></i>Credenciales de acceso
              </h6>

              <div class="row g-3 mb-4">
                <div class="col-12">
                  <label class="form-label">
                    Nombre de usuario <span style="color:#C0392B"><%= docente && docente.id ? '' : '*' %></span>
                  </label>
                  <% if (docente && docente.id) { %>
                  <input type="text" class="form-control"
                         value="<%= usuario ? usuario.username : '' %>" disabled
                         style="background:#F8FAFC;color:#94A3B8">
                  <div class="form-text" style="font-size:0.72rem;color:#94A3B8">
                    El nombre de usuario no puede cambiarse.
                  </div>
                  <% } else { %>
                  <input type="text" name="username" class="form-control"
                         placeholder="solo_letras_numeros_guion_bajo" required
                         pattern="[a-zA-Z0-9_]+"
                         title="Solo letras, números y guion bajo">
                  <div class="form-text" style="font-size:0.72rem;color:#94A3B8">
                    El docente usará este nombre para iniciar sesión.
                  </div>
                  <% } %>
                </div>

                <div class="col-12">
                  <label class="form-label">
                    Contraseña <% if (docente && docente.id) { %><span style="font-size:0.72rem;color:#94A3B8">(dejar vacío para no cambiar)</span><% } else { %><span style="color:#C0392B">*</span><% } %>
                  </label>
                  <input type="password" name="password<%= docente && docente.id ? '_nuevo' : '' %>"
                         class="form-control"
                         <%= docente && docente.id ? '' : 'required' %>
                         placeholder="<%= docente && docente.id ? 'Nueva contraseña (opcional)' : 'Mínimo 6 caracteres' %>"
                         minlength="6">
                </div>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-navy flex-grow-1">
                  <i class="bi bi-<%= docente && docente.id ? 'check-lg' : 'plus-lg' %> me-1"></i>
                  <%= docente && docente.id ? 'Guardar cambios' : 'Crear docente' %>
                </button>
                <a href="/docentes" class="btn" style="border:1px solid #E2E8F0;color:#64748B">Cancelar</a>
              </div>

            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
