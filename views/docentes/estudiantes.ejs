<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'docentes' }) %>
<div id="main-content">

  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="<%= usuario.rol === 'admin' ? '/docentes/' + docente.id : '/dashboard' %>" class="btn btn-sm"
         style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i><%= usuario.rol === 'admin' ? 'Perfil' : 'Inicio' %>
      </a>
      <h1 class="page-title">
        <i class="bi bi-people me-2" style="color:var(--accent)"></i><%= titulo %>
      </h1>
    </div>
    <span class="badge" style="background:#DBEAFE;color:#1A4A8A;font-size:0.78rem">
      Solo lectura
    </span>
  </div>

  <div class="p-4">
    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3"
         style="border-radius:8px;font-size:0.875rem">
      <i class="bi bi-exclamation-circle-fill"></i><%= error %>
    </div>
    <% } %>

    <div class="card">
      <div style="padding:0.75rem 1rem;border-bottom:1px solid #F1F5F9;display:flex;justify-content:space-between;align-items:center">
        <span style="font-size:0.875rem;color:#64748B">
          <strong style="color:var(--navy)"><%= estudiantes.length %></strong>
          estudiantes en tus grados asignados
        </span>
        <%# Búsqueda rápida %>
        <input type="text" id="buscador" placeholder="Buscar estudiante..."
               class="form-control form-control-sm"
               style="width:220px;font-size:0.8rem"
               oninput="filtrar(this.value)">
      </div>

      <% if (estudiantes.length === 0) { %>
      <div class="p-5 text-center">
        <i class="bi bi-people" style="font-size:2.5rem;color:#D3D1C7"></i>
        <p class="mt-3 mb-0" style="color:#94A3B8">
          No tienes estudiantes activos en tus grados asignados.
        </p>
      </div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table table-sm mb-0" id="tabla-est" style="font-size:0.875rem">
          <thead style="background:#F8FAFC">
            <tr>
              <th style="padding:0.7rem 1rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Código</th>
              <th style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Nombre</th>
              <th style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Grado</th>
              <th class="text-center" style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Estado</th>
              <th class="text-center" style="padding:0.7rem;color:#475569;font-weight:600;font-size:0.75rem;text-transform:uppercase">Pago</th>
              <th style="width:80px"></th>
            </tr>
          </thead>
          <tbody>
            <% estudiantes.forEach((est, idx) => {
              const estadoCfg = {
                activo:    { bg:'#DCFCE7', color:'#1E7E4A', label:'Activo' },
                repitente: { bg:'#FFF8E6', color:'#D4870A', label:'Repitente' },
              }[est.estado_matricula] || {};
              const pagoCfg = {
                al_dia:   { bg:'#DCFCE7', color:'#1E7E4A', label:'Al día' },
                pendiente:{ bg:'#FFF8E6', color:'#D4870A', label:'Pendiente' },
              }[est.estado_pago] || {};
            %>
            <tr class="fila-est" style="border-bottom:1px solid #F8FAFC">
              <td style="padding:0.65rem 1rem;color:#64748B;font-size:0.78rem;font-family:'Courier New'">
                <%= est.codigo_estudiante || '—' %>
              </td>
              <td style="padding:0.65rem 0.75rem">
                <div style="font-weight:600;color:var(--navy)">
                  <%= est.apellido1 %><%= est.apellido2 ? ' ' + est.apellido2 : '' %>
                </div>
                <div style="font-size:0.75rem;color:#64748B">
                  <%= est.nombre1 %><%= est.nombre2 ? ' ' + est.nombre2 : '' %>
                </div>
              </td>
              <td style="padding:0.65rem 0.75rem;color:#475569;font-size:0.82rem">
                <%= est.grado ? est.grado.nombre : '—' %>
              </td>
              <td class="text-center" style="padding:0.65rem 0.5rem">
                <span class="badge"
                      style="background:<%= estadoCfg.bg %>;color:<%= estadoCfg.color %>;font-size:0.72rem">
                  <%= estadoCfg.label %>
                </span>
              </td>
              <td class="text-center" style="padding:0.65rem 0.5rem">
                <span class="badge"
                      style="background:<%= pagoCfg.bg %>;color:<%= pagoCfg.color %>;font-size:0.72rem">
                  <%= pagoCfg.label %>
                </span>
              </td>
              <td style="padding:0.65rem 0.75rem;text-align:right">
                <a href="/estudiantes/<%= est.id %>/notas"
                   class="btn btn-sm"
                   style="background:#EDE9FE;color:#6D28D9;border:none;padding:0.25rem 0.65rem;font-size:0.75rem">
                  <i class="bi bi-journal-check me-1" style="font-size:0.75rem"></i>Notas
                </a>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function filtrar(q) {
    const filas = document.querySelectorAll('.fila-est');
    const txt   = q.toLowerCase().trim();
    filas.forEach(f => {
      f.style.display = f.textContent.toLowerCase().includes(txt) ? '' : 'none';
    });
  }
</script>
</body>
</html>
