<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'docentes' }) %>
<div id="main-content">

  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/docentes" class="btn btn-sm" style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
      <h1 class="page-title">
        <i class="bi bi-person-badge me-2" style="color:var(--accent)"></i>Perfil del docente
      </h1>
    </div>
    <div class="d-flex gap-2">
      <a href="/docentes/<%= docente.id %>/asignaciones" class="btn btn-sm"
         style="background:#CCFBF1;color:#0F6E56;border:1px solid #0F6E5620">
        <i class="bi bi-diagram-3 me-1"></i>Asignaciones
      </a>
      <a href="/docentes/<%= docente.id %>/editar" class="btn btn-sm btn-navy">
        <i class="bi bi-pencil me-1"></i>Editar
      </a>
    </div>
  </div>

  <div class="p-4">

    <%# Encabezado %>
    <div class="card mb-4" style="border-left:4px solid #1A4A8A">
      <div style="padding:1rem 1.25rem;display:flex;align-items:center;gap:1rem">
        <div style="width:56px;height:56px;border-radius:50%;background:var(--navy);
                    display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="bi bi-person-badge-fill" style="color:#fff;font-size:1.5rem"></i>
        </div>
        <div style="flex:1">
          <h2 style="font-family:'Playfair Display',serif;color:var(--navy);font-size:1.25rem;margin-bottom:4px">
            <%= docente.nombre %> <%= docente.apellido %>
          </h2>
          <div class="d-flex flex-wrap gap-3 align-items-center">
            <span style="font-size:0.78rem;color:#64748B;font-family:'Courier New'">
              <i class="bi bi-person me-1"></i><%= docente.usuario ? docente.usuario.username : '—' %>
            </span>
            <% if (docente.especialidad) { %>
            <span style="font-size:0.78rem;color:#64748B">
              <i class="bi bi-book me-1"></i><%= docente.especialidad %>
            </span>
            <% } %>
            <span class="badge" style="background:<%= docente.usuario && docente.usuario.activo ? '#DCFCE7' : '#FEE2E2' %>;
                                       color:<%= docente.usuario && docente.usuario.activo ? '#1E7E4A' : '#C0392B' %>">
              <%= docente.usuario && docente.usuario.activo ? 'Activo' : 'Inactivo' %>
            </span>
            <span class="badge" style="background:#CCFBF1;color:#0F6E56">
              <%= docente.asignaciones ? docente.asignaciones.length : 0 %> clases asignadas
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-12 col-lg-5">

        <%# Datos personales %>
        <div class="card mb-4">
          <div class="card-header-custom"><i class="bi bi-person me-2"></i>Datos personales</div>
          <div style="padding:0">
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:140px">Nombre completo</span>
              <span style="color:var(--navy);font-weight:500"><%= docente.nombre %> <%= docente.apellido %></span>
            </div>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:140px">Usuario</span>
              <span style="color:var(--navy);font-weight:500;font-family:'Courier New'">
                <%= docente.usuario ? docente.usuario.username : '—' %>
              </span>
            </div>
            <div class="d-flex border-bottom px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:140px">Teléfono</span>
              <span style="color:var(--navy);font-weight:500"><%= docente.telefono || '—' %></span>
            </div>
            <div class="d-flex px-4 py-2" style="font-size:0.875rem">
              <span style="color:#64748B;min-width:140px">Especialidad</span>
              <span style="color:var(--navy);font-weight:500"><%= docente.especialidad || '—' %></span>
            </div>
          </div>
        </div>

        <%# Acciones rápidas %>
        <div class="card">
          <div class="card-header-custom"><i class="bi bi-lightning me-2"></i>Acciones rápidas</div>
          <div style="padding:0.75rem;display:flex;flex-direction:column;gap:0.5rem">
            <a href="/docentes/<%= docente.id %>/editar"
               class="btn w-100" style="background:#EFF6FF;color:#1A4A8A;justify-content:flex-start">
              <i class="bi bi-pencil me-2"></i>Editar información
            </a>
            <a href="/docentes/<%= docente.id %>/asignaciones"
               class="btn w-100" style="background:#CCFBF1;color:#0F6E56;justify-content:flex-start">
              <i class="bi bi-diagram-3 me-2"></i>Gestionar asignaciones
            </a>
            <form method="POST" action="/docentes/<%= docente.id %>/toggle">
              <button type="submit" class="btn w-100"
                      style="background:<%= docente.usuario && docente.usuario.activo ? '#FFF1F0' : '#F0FDF4' %>;
                             color:<%= docente.usuario && docente.usuario.activo ? '#C0392B' : '#1E7E4A' %>;
                             justify-content:flex-start"
                      onclick="return confirm('¿Confirmas este cambio?')">
                <i class="bi bi-<%= docente.usuario && docente.usuario.activo ? 'person-dash' : 'person-check' %> me-2"></i>
                <%= docente.usuario && docente.usuario.activo ? 'Desactivar docente' : 'Activar docente' %>
              </button>
            </form>
          </div>
        </div>

      </div>

      <div class="col-12 col-lg-7">

        <%# Clases asignadas %>
        <div class="card">
          <div class="card-header-custom d-flex justify-content-between align-items-center">
            <span><i class="bi bi-diagram-3 me-2"></i>Clases asignadas</span>
            <a href="/docentes/<%= docente.id %>/asignaciones"
               class="btn btn-sm" style="background:rgba(255,255,255,0.15);color:#fff;border:1px solid rgba(255,255,255,0.25);font-size:0.75rem">
              <i class="bi bi-gear me-1"></i>Gestionar
            </a>
          </div>

          <% const asigs = docente.asignaciones || []; %>
          <% if (asigs.length === 0) { %>
          <div class="p-4 text-center">
            <i class="bi bi-diagram-3" style="font-size:1.8rem;color:#D3D1C7"></i>
            <p class="mt-2 mb-0" style="color:#94A3B8;font-size:0.875rem">Sin clases asignadas todavía.</p>
          </div>
          <% } else { %>

          <%# Agrupar por grado %>
          <%
            const porGrado = {};
            asigs.forEach(a => {
              const key = a.gradoAsignacion ? a.gradoAsignacion.nombre : 'Sin grado';
              if (!porGrado[key]) porGrado[key] = [];
              porGrado[key].push(a);
            });
          %>
          <div style="padding:0.75rem">
            <% Object.entries(porGrado).forEach(([gradoNombre, materias]) => { %>
            <div class="mb-3">
              <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.05em;
                          color:#94A3B8;margin-bottom:0.4rem"><%= gradoNombre %></div>
              <div class="d-flex flex-wrap gap-1">
                <% materias.forEach(a => { %>
                <span class="badge" style="background:#DBEAFE;color:#1A4A8A;font-size:0.75rem;font-weight:500">
                  <%= a.materia ? a.materia.nombre : '—' %>
                </span>
                <% }); %>
              </div>
            </div>
            <% }); %>
          </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
