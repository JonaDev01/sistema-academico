<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'grados' }) %>

<div id="main-content">

  <%# ── Topbar ── %>
  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/grados" class="btn btn-sm"
         style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
      <h1 class="page-title">
        <i class="bi bi-diagram-3 me-2" style="color:var(--accent)"></i><%= titulo %>
      </h1>
    </div>
  </div>

  <div class="p-4">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">
        <div class="card">

          <div class="card-header-custom">
            <%= grado ? 'Editar grado' : 'Crear nuevo grado' %>
          </div>

          <div class="p-4">

            <%# Errores %>
            <% if (errores && errores.length > 0) { %>
            <div class="alert alert-danger py-2 mb-3" style="border-radius:8px;font-size:0.875rem">
              <% errores.forEach(e => { %>
                <div><i class="bi bi-exclamation-circle me-1"></i><%= e %></div>
              <% }); %>
            </div>
            <% } %>

            <form method="POST"
                  action="/grados/<%= grado && grado.id ? grado.id + '/editar' : 'nuevo' %>">

              <%# Nombre %>
              <div class="mb-3">
                <label class="form-label">
                  Nombre del grado <span style="color:#C0392B">*</span>
                </label>
                <input type="text"
                       name="nombre"
                       class="form-control"
                       placeholder="Ej: 1° Primaria, 3° Secundaria"
                       value="<%= grado ? grado.nombre : '' %>"
                       required>
                <div class="form-text" style="font-size:0.75rem;color:#94A3B8">
                  Usa el formato que el colegio ya maneja internamente.
                </div>
              </div>

              <%# Nivel %>
              <div class="mb-3">
                <label class="form-label">
                  Nivel <span style="color:#C0392B">*</span>
                </label>
                <select name="nivel" class="form-select" required>
                  <option value="">Seleccionar nivel...</option>
                  <option value="preescolar"
                    <%= grado && grado.nivel === 'preescolar' ? 'selected' : '' %>>
                    Preescolar
                  </option>
                  <option value="primaria"
                    <%= grado && grado.nivel === 'primaria' ? 'selected' : '' %>>
                    Primaria
                  </option>
                  <option value="secundaria"
                    <%= grado && grado.nivel === 'secundaria' ? 'selected' : '' %>>
                    Secundaria
                  </option>
                </select>
              </div>

              <%# Orden %>
              <div class="mb-3">
                <label class="form-label">Orden de visualización</label>
                <input type="number"
                       name="orden"
                       class="form-control"
                       placeholder="Ej: 1, 2, 3..."
                       value="<%= grado ? grado.orden : '' %>"
                       min="1">
                <div class="form-text" style="font-size:0.75rem;color:#94A3B8">
                  Define en qué posición aparece en la lista. Si lo dejas vacío se asigna automáticamente al final.
                </div>
              </div>

              <%# Campos de importación %>
              <div class="mb-3">
                <label class="form-label">Nivel de importación (Excel)</label>
                <select name="nivel_importacion" class="form-select">
                  <option value="">Sin asignar</option>
                  <% [
                    'PRIMERO','SEGUNDO','TERCERO','CUARTO','QUINTO','SEXTO',
                    'SEPTIMO','OCTAVO','NOVENO','DECIMO','UNDECIMO'
                  ].forEach(n => { %>
                  <option value="<%= n %>"
                    <%= grado && grado.nivel_importacion === n ? 'selected' : '' %>>
                    <%= n.charAt(0) + n.slice(1).toLowerCase() %>
                  </option>
                  <% }); %>
                </select>
              </div>

              <div class="mb-4">
                <label class="form-label">Modalidad de importación (Excel)</label>
                <select name="modalidad_importacion" class="form-select">
                  <option value="">Sin asignar</option>
                  <% [
                    ['PREESCOLAR FORMAL',  'Preescolar formal'],
                    ['PRIMARIA REGULAR',   'Primaria regular'],
                    ['SECUNDARIA REGULAR', 'Secundaria regular'],
                  ].forEach(([val, label]) => { %>
                  <option value="<%= val %>"
                    <%= grado && grado.modalidad_importacion === val ? 'selected' : '' %>>
                    <%= label %>
                  </option>
                  <% }); %>
                </select>
                <div class="form-text" style="font-size:0.75rem;color:#94A3B8">
                  La combinación Nivel + Modalidad identifica de forma única cada grado en el Excel.
                  Ej: "Primero + Preescolar formal" es diferente a "Primero + Primaria regular".
                </div>
              </div>

              <%# Botones %>
              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-navy flex-grow-1">
                  <i class="bi bi-<%= grado && grado.id ? 'check-lg' : 'plus-lg' %> me-1"></i>
                  <%= grado && grado.id ? 'Guardar cambios' : 'Crear grado' %>
                </button>
                <a href="/grados" class="btn"
                   style="border:1px solid #E2E8F0;color:#64748B">
                  Cancelar
                </a>
              </div>

            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
