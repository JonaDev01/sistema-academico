<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body>
<%- include('../partials/sidebar', { paginaActual: 'grados' }) %>

<div id="main-content">

  <%# ── Topbar ── %>
  <div id="topbar">
    <div class="d-flex align-items-center gap-3">
      <a href="/grados" class="btn btn-sm"
         style="background:var(--bg);border:1px solid #E2E8F0;color:var(--navy)">
        <i class="bi bi-arrow-left me-1"></i>Grados
      </a>
      <h1 class="page-title">
        <i class="bi bi-book me-2" style="color:var(--accent)"></i><%= titulo %>
      </h1>
    </div>
    <span class="badge rounded-pill"
          style="background:<%= grado.nivel === 'primaria' ? '#CCFBF1' : '#DBEAFE' %>;
                 color:<%= grado.nivel === 'primaria' ? '#0F6E56' : '#1A4A8A' %>;
                 font-size:0.8rem;padding:0.4rem 0.8rem">
      <%= grado.nivel.charAt(0).toUpperCase() + grado.nivel.slice(1) %>
    </span>
  </div>

  <div class="p-4">
    <div class="row g-4">

      <%# ── Columna izquierda: lista de materias ── %>
      <div class="col-12 col-lg-7">

        <%# Alertas %>
        <% if (mensaje) { %>
        <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3"
             style="border-radius:8px;font-size:0.875rem">
          <i class="bi bi-check-circle-fill"></i><%= mensaje %>
        </div>
        <% } %>
        <% if (error) { %>
        <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3"
             style="border-radius:8px;font-size:0.875rem">
          <i class="bi bi-exclamation-circle-fill"></i><%= error %>
        </div>
        <% } %>

        <div class="card">
          <div class="card-header-custom d-flex justify-content-between align-items-center">
            <span>Materias de <%= grado.nombre %></span>
            <span style="font-size:0.8rem;opacity:0.7">
              <%= materias.filter(m => m.activo).length %> activas
            </span>
          </div>

          <% if (materias.length === 0) { %>
          <div class="p-5 text-center">
            <i class="bi bi-book" style="font-size:2rem;color:#D3D1C7"></i>
            <p class="mt-3 mb-0" style="color:#94A3B8;font-size:0.875rem">
              No hay materias registradas para este grado.<br>
              Agrega la primera usando el formulario.
            </p>
          </div>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm mb-0" style="font-size:0.875rem">
              <thead style="background:#F8FAFC">
                <tr>
                  <th style="padding:0.7rem 1rem;color:#475569;font-weight:600;
                             font-size:0.75rem;text-transform:uppercase">Materia</th>
                  <th class="text-center"
                      style="padding:0.7rem;color:#475569;font-weight:600;
                             font-size:0.75rem;text-transform:uppercase;width:90px">
                    Estado
                  </th>
                  <th style="width:100px"></th>
                </tr>
              </thead>
              <tbody>
                <% materias.forEach(materia => { %>
                <tr style="border-bottom:1px solid #F1F5F9;
                           opacity:<%= materia.activo ? 1 : 0.5 %>">
                  <td style="padding:0.7rem 1rem;color:#1E293B;font-weight:500">
                    <%= materia.nombre %>
                  </td>
                  <td class="text-center" style="padding:0.7rem">
                    <span class="badge"
                          style="background:<%= materia.activo ? '#DCFCE7' : '#FEE2E2' %>;
                                 color:<%= materia.activo ? '#1E7E4A' : '#C0392B' %>;
                                 font-size:0.72rem">
                      <%= materia.activo ? 'Activa' : 'Inactiva' %>
                    </span>
                  </td>
                  <td style="padding:0.7rem">
                    <div class="d-flex gap-1 justify-content-end">
                      <%# Botón editar — abre modal con datos %>
                      <button class="btn btn-sm"
                              style="background:#EFF6FF;color:#1A4A8A;border:none;padding:0.25rem 0.5rem"
                              onclick="abrirEditar(<%= materia.id %>, '<%= materia.nombre.replace(/'/g, '\\\'') %>')">
                        <i class="bi bi-pencil" style="font-size:0.75rem"></i>
                      </button>
                      <%# Botón toggle %>
                      <form method="POST"
                            action="/grados/<%= grado.id %>/materias/<%= materia.id %>/toggle">
                        <button type="submit" class="btn btn-sm"
                                style="background:<%= materia.activo ? '#FFF1F0' : '#F0FDF4' %>;
                                       color:<%= materia.activo ? '#C0392B' : '#1E7E4A' %>;
                                       border:none;padding:0.25rem 0.5rem"
                                title="<%= materia.activo ? 'Desactivar' : 'Activar' %>">
                          <i class="bi bi-<%= materia.activo ? 'eye-slash' : 'eye' %>"
                             style="font-size:0.75rem"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </div>

      <%# ── Columna derecha: formulario nueva materia ── %>
      <div class="col-12 col-lg-5">
        <div class="card" style="position:sticky;top:80px">
          <div class="card-header-custom" id="form-titulo">
            <i class="bi bi-plus-circle me-2"></i>Nueva materia
          </div>
          <div class="p-4">
            <form method="POST"
                  id="form-materia"
                  action="/grados/<%= grado.id %>/materias/nueva">

              <input type="hidden" id="materia-id" name="_id" value="">

              <div class="mb-4">
                <label class="form-label">
                  Nombre <span style="color:#C0392B">*</span>
                </label>
                <input type="text"
                       name="nombre"
                       id="input-nombre"
                       class="form-control"
                       placeholder="Ej: Matemática, Ciencias Naturales"
                       required>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" id="btn-submit" class="btn btn-navy flex-grow-1">
                  <i class="bi bi-plus-lg me-1"></i>Agregar materia
                </button>
                <button type="button" id="btn-cancelar"
                        class="btn d-none"
                        style="border:1px solid #E2E8F0;color:#64748B"
                        onclick="cancelarEdicion()">
                  Cancelar
                </button>
              </div>

            </form>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<%# ── Modal de confirmación (por si acaso) ── %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const gradoId = '<%= grado.id %>';

  function abrirEditar(id, nombre) {
    document.getElementById('form-materia').action =
      `/grados/${gradoId}/materias/${id}/editar`;
    document.getElementById('input-nombre').value = nombre;
    document.getElementById('materia-id').value   = id;

    // Cambiar título y botón
    document.getElementById('form-titulo').innerHTML =
      '<i class="bi bi-pencil me-2"></i>Editar materia';
    document.getElementById('btn-submit').innerHTML =
      '<i class="bi bi-check-lg me-1"></i>Guardar cambios';

    // Mostrar botón cancelar
    document.getElementById('btn-cancelar').classList.remove('d-none');

    // Scroll al formulario en móvil
    document.getElementById('form-materia').scrollIntoView({ behavior: 'smooth' });
    document.getElementById('input-nombre').focus();
  }

  function cancelarEdicion() {
    document.getElementById('form-materia').action =
      `/grados/${gradoId}/materias/nueva`;
    document.getElementById('input-nombre').value = '';
    document.getElementById('materia-id').value   = '';
    document.getElementById('form-titulo').innerHTML =
      '<i class="bi bi-plus-circle me-2"></i>Nueva materia';
    document.getElementById('btn-submit').innerHTML =
      '<i class="bi bi-plus-lg me-1"></i>Agregar materia';
    document.getElementById('btn-cancelar').classList.add('d-none');
  }
</script>
</body>
</html>
