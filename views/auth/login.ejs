<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <style>
    body { background: var(--navy); display: flex; align-items: center; justify-content: center; min-height: 100vh; }

    .login-card {
      width: 100%;
      max-width: 420px;
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }

    .login-header {
      background: var(--navy);
      padding: 2rem 2rem 1.5rem;
      text-align: center;
      border-bottom: 3px solid var(--accent);
    }

    .login-header h1 {
      font-family: 'Playfair Display', serif;
      color: #fff;
      font-size: 1.4rem;
      margin: 0 0 0.25rem;
    }

    .login-header p {
      color: rgba(255,255,255,0.55);
      font-size: 0.82rem;
      margin: 0;
    }

    .login-body { padding: 2rem; }

    .form-label {
      font-size: 0.82rem;
      font-weight: 600;
      color: #475569;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .form-control {
      border: 1.5px solid #E2E8F0;
      border-radius: 8px;
      padding: 0.65rem 0.9rem;
      font-size: 0.9rem;
      transition: border-color 0.15s;
    }

    .form-control:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(26,74,138,0.1);
    }

    .input-icon { position: relative; }
    .input-icon i {
      position: absolute;
      left: 0.85rem;
      top: 50%;
      transform: translateY(-50%);
      color: #94A3B8;
      font-size: 0.95rem;
    }
    .input-icon .form-control { padding-left: 2.4rem; }

    .btn-login {
      background: var(--navy);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 0.75rem;
      font-size: 0.95rem;
      font-weight: 600;
      width: 100%;
      transition: background 0.15s;
    }
    .btn-login:hover { background: var(--blue); }

    .hint {
      background: #F8FAFC;
      border: 1px solid #E2E8F0;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-size: 0.78rem;
      color: #64748B;
      line-height: 1.6;
    }
  </style>
</head>
<body>

<div class="login-card">

  <div class="login-header">
    <div class="mb-3">
      <i class="bi bi-mortarboard-fill" style="font-size:2.2rem;color:var(--accent)"></i>
    </div>
    <h1>Sistema Académico</h1>
    <p>Ingresa tus credenciales para continuar</p>
  </div>

  <div class="login-body">

    <%# Mensaje de error ── %>
    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" style="font-size:0.875rem;border-radius:8px">
      <i class="bi bi-exclamation-circle-fill"></i>
      <%= error %>
    </div>
    <% } %>

    <form method="POST" action="/login" autocomplete="off">

      <%# Campo único: acepta email o username %>
      <div class="mb-3">
        <label class="form-label">Correo o usuario</label>
        <div class="input-icon">
          <i class="bi bi-person"></i>
          <input
            type="text"
            name="credencial"
            class="form-control"
            placeholder="correo@ejemplo.com  o  profe_garcia"
            autofocus
            required
          >
        </div>
        <div class="form-text" style="font-size:0.75rem;color:#94A3B8">
          Administradores usan correo · Docentes usan nombre de usuario
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label">Contraseña</label>
        <div class="input-icon">
          <i class="bi bi-lock"></i>
          <input
            type="password"
            name="password"
            class="form-control"
            placeholder="••••••••"
            required
          >
        </div>
      </div>

      <button type="submit" class="btn-login">
        <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
      </button>

    </form>

    <div class="hint mt-3">
      <i class="bi bi-info-circle me-1"></i>
      Si olvidaste tu contraseña, contacta al administrador del sistema.
    </div>

  </div>
</div>

<%# Bootstrap JS (solo para posibles tooltips futuros) %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
