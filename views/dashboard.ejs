<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('./partials/head') %>
</head>
<body>

<%- include('./partials/sidebar', { paginaActual: 'dashboard' }) %>

<div id="main-content">

  <%# Topbar ── %>
  <div id="topbar">
    <h1 class="page-title">
      <i class="bi bi-speedometer2 me-2" style="color:var(--accent)"></i>Dashboard
    </h1>
    <div class="d-flex align-items-center gap-2">
      <span class="badge rounded-pill"
            style="background:var(--navy);font-size:0.75rem;padding:0.4rem 0.8rem">
        <i class="bi bi-calendar3 me-1"></i>
        <%= new Date().toLocaleDateString('es-GT', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
      </span>
    </div>
  </div>

  <%# Contenido ── %>
  <div class="p-4">

    <%# Bienvenida ── %>
    <div class="mb-4">
      <h2 style="font-family:'Playfair Display',serif;color:var(--navy);font-size:1.4rem;margin:0">
        Bienvenido, <%= usuario.nombre %> 👋
      </h2>
      <p class="text-muted mb-0" style="font-size:0.875rem">
        <%= usuario.rol === 'admin' ? 'Administrador del sistema' : 'Docente' %>
      </p>
    </div>

    <% if (usuario.rol === 'admin') { %>

      <%# ── Fila 1: stats principales ── %>
      <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
          <div class="card stat-card p-3" style="border-left-color:var(--accent)">
            <div class="stat-number"><%= stats.totalEstudiantes || 0 %></div>
            <div class="stat-label">Estudiantes activos</div>
            <a href="/estudiantes" class="stretched-link"></a>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card stat-card p-3" style="border-left-color:#1A4A8A">
            <div class="stat-number"><%= stats.totalDocentes || 0 %></div>
            <div class="stat-label">Docentes</div>
            <a href="/docentes" class="stretched-link"></a>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card stat-card p-3" style="border-left-color:#0F6E56">
            <div class="stat-number"><%= stats.totalGrados || 0 %></div>
            <div class="stat-label">Grados activos</div>
            <a href="/grados" class="stretched-link"></a>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card stat-card p-3" style="border-left-color:#6D28D9">
            <div class="stat-number">
              <%= stats.periodoActivo ? `C${stats.periodoActivo.corte}` : '—' %>
            </div>
            <div class="stat-label">
              Corte activo
              <% if (stats.periodoActivo) { %>
              <span class="d-block" style="font-size:0.7rem"><%= stats.periodoActivo.anio %></span>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <%# ── Fila 2: stats secundarias ── %>
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="card p-3" style="border-left:4px solid #D4870A">
            <div style="font-size:1.5rem;font-weight:700;color:#D4870A"><%= stats.totalRepitentes || 0 %></div>
            <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase;letter-spacing:0.04em">Repitentes</div>
            <a href="/estudiantes?estado_matricula=repitente" class="stretched-link"></a>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card p-3" style="border-left:4px solid #C0392B">
            <div style="font-size:1.5rem;font-weight:700;color:#C0392B"><%= stats.totalPagosPendientes || 0 %></div>
            <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase;letter-spacing:0.04em">Pagos pendientes</div>
            <a href="/estudiantes?estado_pago=pendiente" class="stretched-link"></a>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card p-3" style="border-left:4px solid #6D28D9">
            <div style="font-size:1.5rem;font-weight:700;color:#6D28D9"><%= stats.totalBecados || 0 %></div>
            <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase;letter-spacing:0.04em">Con beca</div>
            <a href="/estudiantes" class="stretched-link"></a>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card p-3" style="border-left:4px solid #0F6E56">
            <div style="font-size:1.5rem;font-weight:700;color:#0F6E56"><%= stats.totalNotas || 0 %></div>
            <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase;letter-spacing:0.04em">Notas registradas</div>
            <a href="/notas" class="stretched-link"></a>
          </div>
        </div>
      </div>

      <%# ── Accesos rápidos ── %>
      <h5 style="font-family:'Playfair Display',serif;color:var(--navy)" class="mb-3">
        Accesos rápidos
      </h5>

      <div class="row g-3">

        <div class="col-12 col-md-4">
          <a href="/estudiantes/nuevo" class="card p-3 text-decoration-none d-flex flex-row align-items-center gap-3"
             style="border-left:4px solid var(--accent)">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:44px;height:44px;background:#FFF8E6;flex-shrink:0">
              <i class="bi bi-person-plus" style="color:var(--accent);font-size:1.2rem"></i>
            </div>
            <div>
              <div class="fw-600" style="color:var(--navy);font-size:0.9rem">Nuevo estudiante</div>
              <div class="text-muted" style="font-size:0.78rem">Registrar manualmente</div>
            </div>
          </a>
        </div>

        <div class="col-12 col-md-4">
          <a href="/estudiantes/importar" class="card p-3 text-decoration-none d-flex flex-row align-items-center gap-3"
             style="border-left:4px solid #0F6E56">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:44px;height:44px;background:#DCFCE7;flex-shrink:0">
              <i class="bi bi-file-earmark-excel" style="color:#0F6E56;font-size:1.2rem"></i>
            </div>
            <div>
              <div class="fw-600" style="color:var(--navy);font-size:0.9rem">Importar Excel</div>
              <div class="text-muted" style="font-size:0.78rem">Carga masiva de alumnos</div>
            </div>
          </a>
        </div>

        <div class="col-12 col-md-4">
          <a href="/docentes/nuevo" class="card p-3 text-decoration-none d-flex flex-row align-items-center gap-3"
             style="border-left:4px solid #1A4A8A">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:44px;height:44px;background:#DBEAFE;flex-shrink:0">
              <i class="bi bi-person-badge" style="color:#1A4A8A;font-size:1.2rem"></i>
            </div>
            <div>
              <div class="fw-600" style="color:var(--navy);font-size:0.9rem">Nuevo docente</div>
              <div class="text-muted" style="font-size:0.78rem">Crear perfil y acceso</div>
            </div>
          </a>
        </div>

        <div class="col-12 col-md-4">
          <a href="/grados" class="card p-3 text-decoration-none d-flex flex-row align-items-center gap-3"
             style="border-left:4px solid #6D28D9">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:44px;height:44px;background:#EDE9FE;flex-shrink:0">
              <i class="bi bi-diagram-3" style="color:#6D28D9;font-size:1.2rem"></i>
            </div>
            <div>
              <div class="fw-600" style="color:var(--navy);font-size:0.9rem">Grados y materias</div>
              <div class="text-muted" style="font-size:0.78rem">Gestionar estructura</div>
            </div>
          </a>
        </div>

        <div class="col-12 col-md-4">
          <a href="/notas" class="card p-3 text-decoration-none d-flex flex-row align-items-center gap-3"
             style="border-left:4px solid #854F0B">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:44px;height:44px;background:#FFF8E6;flex-shrink:0">
              <i class="bi bi-journal-check" style="color:#854F0B;font-size:1.2rem"></i>
            </div>
            <div>
              <div class="fw-600" style="color:var(--navy);font-size:0.9rem">Registrar notas</div>
              <div class="text-muted" style="font-size:0.78rem">Corte <%= stats.periodoActivo ? stats.periodoActivo.corte : '—' %></div>
            </div>
          </a>
        </div>

        <div class="col-12 col-md-4">
          <a href="/boletin" class="card p-3 text-decoration-none d-flex flex-row align-items-center gap-3"
             style="border-left:4px solid #993556">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:44px;height:44px;background:#FBEAF0;flex-shrink:0">
              <i class="bi bi-file-earmark-pdf" style="color:#993556;font-size:1.2rem"></i>
            </div>
            <div>
              <div class="fw-600" style="color:var(--navy);font-size:0.9rem">Boletín PDF</div>
              <div class="text-muted" style="font-size:0.78rem">Generar por estudiante</div>
            </div>
          </a>
        </div>

      </div>

    <% } else { %>

      <%# ── Vista del docente ── %>
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="card p-3" style="border-left:4px solid var(--accent)">
            <div style="font-size:1.8rem;font-weight:700;color:var(--navy)"><%= stats.clases || 0 %></div>
            <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase">Clases asignadas</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card p-3" style="border-left:4px solid #1A4A8A">
            <div style="font-size:1.8rem;font-weight:700;color:var(--navy)"><%= stats.estudiantes || 0 %></div>
            <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase">Estudiantes</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card p-3" style="border-left:4px solid #0F6E56">
            <div style="font-size:1.8rem;font-weight:700;color:var(--navy)"><%= stats.notasIngresadas || 0 %></div>
            <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase">Notas ingresadas</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card p-3" style="border-left:4px solid #6D28D9">
            <div style="font-size:1.8rem;font-weight:700;color:var(--navy)">
              <%= stats.periodoActivo ? `C${stats.periodoActivo.corte}` : '—' %>
            </div>
            <div style="font-size:0.72rem;color:#64748B;text-transform:uppercase">
              Corte activo
              <% if (stats.periodoActivo) { %>
              <span class="d-block"><%= stats.periodoActivo.anio %></span>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-12 col-md-6">
          <a href="/notas" class="card p-4 text-decoration-none d-flex flex-row align-items-center gap-3"
             style="border-left:4px solid var(--accent)">
            <i class="bi bi-journal-check" style="font-size:2rem;color:var(--accent)"></i>
            <div>
              <div class="fw-600" style="color:var(--navy)">Registrar Notas</div>
              <div class="text-muted" style="font-size:0.85rem">Ver y registrar notas de tus clases</div>
            </div>
          </a>
        </div>
        <div class="col-12 col-md-6">
          <a href="/estudiantes" class="card p-4 text-decoration-none d-flex flex-row align-items-center gap-3"
             style="border-left:4px solid #1A4A8A">
            <i class="bi bi-people" style="font-size:2rem;color:#1A4A8A"></i>
            <div>
              <div class="fw-600" style="color:var(--navy)">Ver Estudiantes</div>
              <div class="text-muted" style="font-size:0.85rem">Consultar información de tus alumnos</div>
            </div>
          </a>
        </div>
      </div>

    <% } %>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
